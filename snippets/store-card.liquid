{% liquid
  assign sc_bg             = store_card_bg     | default: '#ffffff'
  assign sc_border         = store_card_border | default: '#E5E7EB'
  assign sc_border_w       = store_card_border_width | default: 1
  assign sc_border_hover   = store_card_border_hover | default: '#0058BB'
  assign sc_radius         = store_card_radius | default: 16
  assign sc_title_color    = store_card_title_color | default: '#1a1c1c'
  assign sc_title_hover    = store_card_title_hover | default: '#0058BB'
  assign sc_muted_color    = store_card_muted_color | default: '#6B7280'
  assign sc_badge_bg       = store_card_badge_bg | default: '#0058BB'
  assign sc_badge_text     = store_card_badge_text | default: '#ffffff'
  assign sc_icon_color     = store_card_icon_color | default: '#0058BB'
  assign sc_media_bg       = store_card_media_bg | default: '#F7F7F7'
  assign sc_image_fit      = store_card_image_fit | default: 'cover'
%}

{% capture card_inner %}
  {%- comment -%}── Imagem ────────────────────────────────────────────────{%- endcomment -%}
  <div class="store-card__media overflow-hidden" style="border-radius: calc({{ sc_radius }}px - {{ sc_border_w }}px) calc({{ sc_radius }}px - {{ sc_border_w }}px) 0 0; background-color: {{ sc_media_bg }};">
    {% if store_image != blank %}
      {{ store_image | image_url: width: 600 | image_tag:
        loading: 'lazy',
        alt: store_name,
        class: 'store-card__img w-full h-full block',
        style: 'object-fit: ' | append: sc_image_fit | append: '; object-position: center center;'
      }}
    {% else %}
      <div class="w-full h-full flex items-center justify-center">
        <span class="material-symbols-outlined" style="font-size: 48px; color: {{ sc_muted_color }}; opacity: 0.35;">store</span>
      </div>
    {% endif %}

    {% if store_badge != blank %}
      <span class="store-card__badge absolute top-3 left-3 px-2 py-1 text-[11px] font-bold uppercase tracking-wide leading-none rounded-md" style="background-color: {{ sc_badge_bg }}; color: {{ sc_badge_text }};">
        {{ store_badge }}
      </span>
    {% endif %}
  </div>

  {%- comment -%}── Conteúdo ──────────────────────────────────────────────{%- endcomment -%}
  <div class="store-card__body flex flex-col gap-2 p-4" style="flex: 1;">
    {%- comment -%} Nome da loja {%- endcomment -%}
    <h3 class="store-card__title font-bold leading-snug" style="font-size: var(--sc-title-size-mobile, 15px); color: {{ sc_title_color }};">
      {{ store_name | default: 'Nome da Loja' }}
    </h3>

    {%- comment -%} Endereço {%- endcomment -%}
    {% if store_address != blank %}
      <p class="store-card__address flex items-start gap-1.5 leading-snug" style="font-size: var(--sc-meta-size-mobile, 13px); color: {{ sc_muted_color }};">
        <span class="material-symbols-outlined text-base mt-[1px] shrink-0" style="font-size: 15px; color: {{ sc_icon_color }};">location_on</span>
        {{ store_address }}
      </p>
    {% endif %}

    {%- comment -%} Horário {%- endcomment -%}
    {% if store_hours != blank %}
      <p class="store-card__hours flex items-start gap-1.5 leading-snug" style="font-size: var(--sc-meta-size-mobile, 13px); color: {{ sc_muted_color }};">
        <span class="material-symbols-outlined text-base mt-[1px] shrink-0" style="font-size: 15px; color: {{ sc_icon_color }};">schedule</span>
        {{ store_hours }}
      </p>
    {% endif %}

    {%- comment -%} Telefone {%- endcomment -%}
    {% if store_phone != blank %}
      <p class="store-card__phone flex items-start gap-1.5 leading-snug" style="font-size: var(--sc-meta-size-mobile, 13px); color: {{ sc_muted_color }};">
        <span class="material-symbols-outlined text-base mt-[1px] shrink-0" style="font-size: 15px; color: {{ sc_icon_color }};">phone</span>
        {{ store_phone }}
      </p>
    {% endif %}

  </div>
{% endcapture %}

{% if store_cta_url != blank %}
  <a href="{{ store_cta_url }}" class="store-card gc-unified-card flex flex-col relative overflow-hidden transition-all duration-200" style="background-color: {{ sc_bg }}; border: {{ sc_border_w }}px solid {{ sc_border }}; border-radius: {{ sc_radius }}px; --gc-card-bg-local: {{ sc_bg }}; --gc-card-border-local: {{ sc_border }}; --gc-card-border-width-local: {{ sc_border_w }}px; --gc-card-radius-local: {{ sc_radius }}px; --gc-card-border-hover-local: {{ sc_border_hover }}; --gc-card-lift-hover: -3px;">
    {{ card_inner }}
  </a>
{% else %}
  <div class="store-card gc-unified-card flex flex-col relative overflow-hidden transition-all duration-200" style="background-color: {{ sc_bg }}; border: {{ sc_border_w }}px solid {{ sc_border }}; border-radius: {{ sc_radius }}px; --gc-card-bg-local: {{ sc_bg }}; --gc-card-border-local: {{ sc_border }}; --gc-card-border-width-local: {{ sc_border_w }}px; --gc-card-radius-local: {{ sc_radius }}px; --gc-card-border-hover-local: {{ sc_border_hover }}; --gc-card-lift-hover: -3px;">
    {{ card_inner }}
  </div>
{% endif %}
