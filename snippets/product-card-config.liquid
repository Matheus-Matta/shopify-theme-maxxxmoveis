{% comment %}
  =====================================
  Configuração Centralizada de Product Cards
  =====================================
  
  Este snippet centraliza TODAS as configurações globais de cards de produtos.
  
  Reutilize em:
  - collection-tabs-carousel.liquid
  - collection-dynamic.liquid (recomendados)
  - collection-plp-reusable.liquid (busca/coleção)
  - product-page-custom.liquid (produtos recomendados)
  
  Como usar:
  {% include 'product-card-config' %}
  
  Variáveis disponíveis após inclusão:
  - card_config: Objeto com todas as configs de cards
  - product_card_*: Variáveis individuais (compatibilidade com código legado)
  
  Estrutura de card_config:
  {
    layout: { width_mobile, width_desktop, height_mobile, height_desktop, media_height_mobile, media_height_desktop },
    styling: { bg_color, border_color, border_hover_color, border_width, radius, padding },
    colors: { title, title_hover, price, meta, media_bg, discount_badge_bg, discount_badge_text, rating },
    content: { show_ratings, show_buy_button, show_discount_badge, buy_label, min_inventory },
    image: { fit, position, render_mode },
    typography: { meta_size_mobile, meta_size_desktop }
  }
{% endcomment %}

{% liquid
  assign card_width_mobile = settings.global_product_card_width_mobile | default: 230
  assign card_width_desktop = settings.global_product_card_width_desktop | default: 270
  assign card_height_mobile = settings.global_product_card_height_mobile | default: 430
  assign card_height_desktop = settings.global_product_card_height_desktop | default: 500
  assign card_media_height_mobile = settings.global_product_card_media_height_mobile | default: 230
  assign card_media_height_desktop = settings.global_product_card_media_height_desktop | default: 270
  
  assign card_bg = settings.global_product_card_bg_color | default: settings.global_surface_card_color | default: settings.surface_card_color
  assign card_border = settings.global_product_card_border_color | default: settings.global_border_color | default: settings.border_color
  assign card_border_hover = settings.global_product_card_border_hover_color | default: settings.global_primary_color | default: settings.accent_color
  assign card_border_width = settings.global_product_card_border_width | default: 1
  assign card_radius = settings.global_product_card_radius | default: 16
  assign card_padding = settings.global_product_card_padding | default: 16
  
  assign card_title = settings.global_product_card_title_color | default: settings.global_text_primary_color | default: settings.text_color
  assign card_title_hover = settings.global_product_card_title_hover_color | default: settings.global_primary_color | default: settings.accent_color
  assign card_price = settings.global_product_card_price_color | default: settings.global_text_primary_color | default: settings.text_color
  assign card_meta = settings.global_product_card_meta_color | default: settings.global_text_muted_color | default: settings.muted_color
  assign card_rating_color = settings.global_product_card_rating_color | default: '#facc15'
  
  assign media_bg = settings.global_product_card_media_bg_color | default: settings.surface_color
  assign media_render_mode = settings.global_product_card_media_render_mode | default: 'background'
  assign product_image_fit = settings.global_product_card_image_fit | default: 'cover'
  assign product_image_position = settings.global_product_card_image_position | default: 'center center'
  
  assign discount_badge_bg = settings.global_product_card_discount_badge_bg | default: settings.global_primary_color | default: settings.accent_color
  assign discount_badge_text = settings.global_product_card_discount_badge_text | default: settings.accent_contrast
  
  assign show_ratings = settings.global_product_card_show_ratings
  assign show_buy_button = settings.global_product_card_show_buy_button
  assign show_discount_badge = settings.global_product_card_show_discount_badge
  assign card_buy_label = settings.global_product_card_buy_label | default: 'COMPRAR'
  assign product_min_inventory = settings.global_product_card_min_inventory | default: 0 | plus: 0
  
  assign card_meta_size_mobile = settings.global_product_card_meta_size_mobile | default: 12
  assign card_meta_size_desktop = settings.global_product_card_meta_size_desktop | default: 12
%}

