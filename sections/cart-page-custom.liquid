{% liquid
  assign section_bg = section.settings.background_color | default: settings.global_surface_subtle_color
  assign card_bg = settings.global_surface_card_color
  assign card_border = settings.global_border_color
  assign heading_color = settings.global_text_primary_color
  assign text_color = settings.global_text_primary_color
  assign muted_color = settings.global_text_muted_color
  assign accent_color = settings.global_primary_color
  assign button_bg = section.settings.checkout_btn_bg | default: settings.global_button_primary_bg_color
  assign button_bg_hover = section.settings.checkout_btn_bg_hover | default: settings.global_button_primary_bg_hover_color | default: '#004A9D'
  assign button_text = section.settings.checkout_btn_text | default: settings.global_button_primary_text_color
  assign button_radius = section.settings.checkout_btn_radius | default: 10
  assign button_text_size = section.settings.checkout_btn_text_size | default: 14
  assign keep_btn_text = section.settings.keep_shopping_btn_text | default: settings.global_text_primary_color
  assign keep_btn_border = section.settings.keep_shopping_btn_border | default: settings.global_border_color | default: '#E5E7EB'
  assign keep_btn_radius = section.settings.keep_shopping_btn_radius | default: 10
  assign cart_currency = cart.currency.iso_code | default: shop.currency
%}

<style>
  #shopify-section-{{ section.id }} .cart-page {
    background: {{ section_bg }};
    color: {{ text_color }};
    padding: 3rem 0;
  }

  #shopify-section-{{ section.id }} .cart-page__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  #shopify-section-{{ section.id }} .cart-page__header {
    margin-bottom: 1.5rem;
  }

  #shopify-section-{{ section.id }} .cart-page__title {
    margin: 0;
    color: {{ heading_color }};
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.2;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .cart-page__subtitle {
    margin: 0.5rem 0 0;
    color: {{ muted_color }};
    font-size: 0.95rem;
  }

  #shopify-section-{{ section.id }} .cart-page__grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  #shopify-section-{{ section.id }} .cart-items-list {
    display: grid;
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .cart-card {
    background: {{ card_bg }};
    border: 1px solid {{ card_border }};
    border-radius: 14px;
    padding: 1rem;
  }

  #shopify-section-{{ section.id }} .cart-item {
    display: grid;
    grid-template-columns: 112px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1rem;
  }

  #shopify-section-{{ section.id }} .cart-item-card {
    border-radius: 16px;
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.03);
  }

  #shopify-section-{{ section.id }} .cart-item__media {
    width: 112px;
    height: 112px;
    border-radius: 10px;
    overflow: hidden;
    background: #f2f2f2;
  }

  #shopify-section-{{ section.id }} .cart-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .cart-item__title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.35;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .cart-item__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.9rem;
  }

  #shopify-section-{{ section.id }} .cart-item__title a {
    color: {{ heading_color }};
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .cart-item__title a:hover {
    color: {{ accent_color }};
  }

  #shopify-section-{{ section.id }} .cart-item__meta {
    margin-top: 0.4rem;
    color: {{ muted_color }};
    font-size: 0.88rem;
  }

  #shopify-section-{{ section.id }} .cart-item__properties {
    margin-top: 0.35rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  #shopify-section-{{ section.id }} .cart-item__property {
    display: inline-flex;
    align-items: center;
    font-size: 0.78rem;
    line-height: 1;
    color: {{ muted_color }};
    background: color-mix(in srgb, {{ muted_color }} 10%, transparent);
    border: 1px solid color-mix(in srgb, {{ muted_color }} 20%, transparent);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
  }

  #shopify-section-{{ section.id }} .cart-item__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.8rem;
  }

  #shopify-section-{{ section.id }} .cart-item__price {
    color: {{ heading_color }};
    font-weight: 400;
    font-size: 1.06rem;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .cart-item__qty {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: {{ muted_color }};
    font-size: 0.9rem;
  }

  #shopify-section-{{ section.id }} .cart-item__qty-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid {{ card_border }};
    border-radius: 999px;
    min-height: 34px;
    padding: 0 2px;
    background: #fff;
  }

  #shopify-section-{{ section.id }} .cart-item__qty-btn {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: {{ muted_color }};
    cursor: pointer;
    border-radius: 999px;
    transition: background-color 0.18s ease, color 0.18s ease;
  }

  #shopify-section-{{ section.id }} .cart-item__qty-btn:hover {
    color: {{ accent_color }};
    background: color-mix(in srgb, {{ accent_color }} 10%, #fff);
  }

  #shopify-section-{{ section.id }} .cart-item__qty-value {
    width: 34px;
    min-height: 30px;
    border: 0;
    background: transparent;
    text-align: center;
    color: {{ heading_color }};
    font-weight: 400;
    font-size: 0.9rem;
    outline: none;
    -moz-appearance: textfield;
  }

  #shopify-section-{{ section.id }} .cart-item__qty-value::-webkit-outer-spin-button,
  #shopify-section-{{ section.id }} .cart-item__qty-value::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .cart-item__qty-input {
    width: 72px;
    min-height: 34px;
    border: 1px solid {{ card_border }};
    border-radius: 8px;
    padding: 0 8px;
    text-align: center;
    color: {{ heading_color }};
    background: #fff;
  }

  #shopify-section-{{ section.id }} .cart-item__remove {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: {{ muted_color }};
    text-decoration: none;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .cart-item__remove:hover {
    color: {{ accent_color }};
  }

  #shopify-section-{{ section.id }} .cart-summary__title {
    margin: 0;
    color: {{ heading_color }};
    font-size: 1.2rem;
    font-weight: 600;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid {{ card_border }};
  }

  #shopify-section-{{ section.id }} .cart-summary__row {
    margin-top: 0.9rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    color: {{ text_color }};
    font-size: 0.95rem;
  }

  #shopify-section-{{ section.id }} .cart-summary__row--total {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid {{ card_border }};
    font-weight: 400;
    color: {{ heading_color }};
    font-size: 1.05rem;
  }

  #shopify-section-{{ section.id }} .cart-summary__actions {
    margin-top: 1.25rem;
    display: grid;
    gap: 0.75rem;
  }

  #shopify-section-{{ section.id }} .cart-btn {
    border: 1px solid transparent;
    border-radius: {{ button_radius }}px;
    min-height: 44px;
    padding: 0.7rem 1rem;
    text-align: center;
    text-decoration: none;
    font-weight: 400;
    font-size: {{ button_text_size }}px;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .cart-btn--primary {
    background: {{ button_bg }};
    color: {{ button_text }};
  }

  #shopify-section-{{ section.id }} .cart-btn--primary:hover {
    background: {{ button_bg_hover }};
  }

  #shopify-section-{{ section.id }} .cart-btn--secondary {
    border-color: {{ keep_btn_border }};
    border-radius: {{ keep_btn_radius }}px;
    color: {{ keep_btn_text }};
    background: transparent;
  }

  #shopify-section-{{ section.id }} .cart-btn--secondary:hover {
    border-color: {{ accent_color }};
    color: {{ accent_color }};
  }

  #shopify-section-{{ section.id }} .cart-empty {
    text-align: center;
    padding: 2rem 1rem;
  }

  #shopify-section-{{ section.id }} .cart-empty__title {
    margin: 0;
    color: {{ heading_color }};
    font-size: 1.3rem;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .cart-empty__text {
    margin: 0.6rem 0 0;
    color: {{ muted_color }};
  }

  #shopify-section-{{ section.id }} .cart-empty__helper {
    margin: 0.4rem 0 0;
    color: {{ muted_color }};
    font-size: 0.9rem;
  }

  #shopify-section-{{ section.id }} .cart-mobile-checkout {
    display: none;
  }

  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .cart-page {
      padding: 4rem 0;
    }

    #shopify-section-{{ section.id }} .cart-page__grid {
      grid-template-columns: minmax(0, 1.8fr) minmax(320px, 1fr);
      gap: 2rem;
      align-items: start;
    }

    #shopify-section-{{ section.id }} .cart-card {
      padding: 1.25rem;
    }

    #shopify-section-{{ section.id }} .cart-summary {
      position: sticky;
      top: 1.25rem;
      padding: 1.6rem;
    }
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .cart-page {
      padding: 2rem 0;
    }

    #shopify-section-{{ section.id }} .cart-page--has-mobile-sticky {
      padding-bottom: calc(4.6rem + env(safe-area-inset-bottom));
    }

    #shopify-section-{{ section.id }} .cart-item {
      grid-template-columns: 76px 1fr;
      gap: 0.7rem;
      padding: 0.75rem;
    }

    #shopify-section-{{ section.id }} .cart-item__media {
      width: 76px;
      height: 76px;
      border-radius: 8px;
    }

    #shopify-section-{{ section.id }} .cart-item__title {
      font-size: 0.9rem;
      line-height: 1.28;
    }

    #shopify-section-{{ section.id }} .cart-item__head {
      gap: 0.45rem;
      align-items: flex-start;
    }

    #shopify-section-{{ section.id }} .cart-item__price {
      font-size: 0.9rem;
    }

    #shopify-section-{{ section.id }} .cart-item__row {
      margin-top: 0.55rem;
      gap: 0.5rem;
    }

    #shopify-section-{{ section.id }} .cart-item__qty {
      gap: 0.3rem;
      font-size: 0.82rem;
    }

    #shopify-section-{{ section.id }} .cart-item__qty-control {
      min-height: 30px;
      min-width: 98px;
      justify-content: space-between;
    }

    #shopify-section-{{ section.id }} .cart-item__qty-btn {
      width: 26px;
      height: 26px;
    }

    #shopify-section-{{ section.id }} .cart-item__qty-value {
      width: 34px;
      min-height: 26px;
      font-size: 0.82rem;
    }

    #shopify-section-{{ section.id }} .cart-item__remove {
      font-size: 0.74rem;
      letter-spacing: 0.05em;
      gap: 0.22rem;
    }

    #shopify-section-{{ section.id }} .cart-summary__actions .cart-btn--primary {
      display: none;
    }

    #shopify-section-{{ section.id }} .cart-mobile-checkout {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1050;
      padding: 0.55rem 0.8rem calc(0.55rem + env(safe-area-inset-bottom));
      background: color-mix(in srgb, {{ card_bg }} 92%, #ffffff 8%);
      border-top: 1px solid {{ card_border }};
      box-shadow: 0 -8px 22px rgba(15, 23, 42, 0.1);
      display: block;
    }

    #shopify-section-{{ section.id }} .cart-mobile-checkout__inner {
      max-width: {{ section.settings.container_width }}px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.8rem;
    }

    #shopify-section-{{ section.id }} .cart-mobile-checkout__meta {
      min-width: 0;
    }

      font-weight: 400;
      margin: 0;
      color: {{ muted_color }};
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      line-height: 1.1;
    }

    #shopify-section-{{ section.id }} .cart-mobile-checkout__total {
      margin: 0.18rem 0 0;
      color: {{ heading_color }};
      font-size: 1.02rem;
      font-weight: 400;
      line-height: 1.2;
    }

    #shopify-section-{{ section.id }} .cart-mobile-checkout__button {
      min-height: 44px;
      padding: 0.68rem 1rem;
      white-space: nowrap;
    }
  }

  @keyframes cart-btn-spin {
    to { transform: rotate(360deg); }
  }

  #shopify-section-{{ section.id }} .cart-btn.is-loading {
    opacity: 0.72;
    pointer-events: none;
    cursor: default;
    position: relative;
  }

  #shopify-section-{{ section.id }} .cart-btn.is-loading::after {
    content: '';
    display: inline-block;
    width: 13px;
    height: 13px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: cart-btn-spin 0.6s linear infinite;
    margin-left: 7px;
    vertical-align: middle;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .cart-item__remove.is-loading {
    opacity: 0.5;
    pointer-events: none;
    cursor: default;
  }
</style>

<section class="cart-page{% if cart.item_count > 0 %} cart-page--has-mobile-sticky{% endif %}">
  <div class="cart-page__container">
    <div data-cart-full-content{% unless cart.item_count > 0 %} style="display:none"{% endunless %}>
    {% if cart.item_count > 0 %}
      <header class="cart-page__header">
        <h1 class="cart-page__title font-semibold">{{ section.settings.title | escape }}</h1>
        <p class="cart-page__subtitle">{{ section.settings.subtitle | escape }}</p>
      </header>

      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="cart-page__grid">
          <div class="cart-items-list">
          {% for item in cart.items %}
            <article class="cart-item cart-card cart-item-card" data-cart-item-key="{{ item.key }}" data-cart-line="{{ forloop.index }}">
              <a class="cart-item__media" href="{{ item.url }}" aria-label="{{ item.product.title | escape }}">
                {% if item.image %}
                  {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', widths: '120,180,240', alt: item.product.title }}
                {% endif %}
              </a>

              <div>
                <div class="cart-item__head">
                  <h2 class="cart-item__title font-medium"><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                  <strong class="cart-item__price" data-cart-line-price{% if item.variant.compare_at_price > item.price %} style="color: var(--color-promo-final-price)"{% endif %}>{{ item.final_line_price | money }}</strong>
                </div>

                {% unless item.properties == empty %}
                  {%- assign has_visible_props = false -%}
                  {%- for property in item.properties -%}
                    {%- assign prop_key = property.first -%}
                    {%- assign prop_value = property.last -%}
                    {%- unless prop_key == blank or prop_value == blank or prop_key contains '_tpo_' or prop_key == '_easify_id' or prop_key == '_tpo_add_by' -%}
                      {%- assign has_visible_props = true -%}
                    {%- endunless -%}
                  {%- endfor -%}
                  {% if has_visible_props %}
                    <div class="cart-item__properties">
                      {% for property in item.properties %}
                        {%- assign prop_key = property.first -%}
                        {%- assign prop_value = property.last -%}
                        {%- unless prop_key == blank or prop_value == blank or prop_key contains '_tpo_' or prop_key == '_easify_id' or prop_key == '_tpo_add_by' -%}
                          <span class="cart-item__property">{{ prop_value }}</span>
                        {%- endunless -%}
                      {% endfor %}
                    </div>
                  {% endif %}
                {% endunless %}

                {% assign cart_variant_title = item.variant.title | default: '' | strip %}
                {% unless cart_variant_title == blank or cart_variant_title | downcase == 'default title' %}
                  <p class="cart-item__meta">{{ cart_variant_title }}</p>
                {% endunless %}

                <div class="cart-item__row">
                  <div class="cart-item__qty">
                    <span>{{ section.settings.quantity_label }}:</span>
                    <div class="cart-item__qty-control" data-cart-qty-control>
                      <button class="cart-item__qty-btn" type="button" data-cart-qty-decrease aria-label="Diminuir quantidade">
                        <span class="material-symbols-outlined text-base">remove</span>
                      </button>
                      <input
                        class="cart-item__qty-value"
                        id="updates_{{ item.key }}"
                        name="updates[]"
                        type="text"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        value="{{ item.quantity }}"
                        data-cart-qty-input
                        aria-label="{{ section.settings.quantity_label }} {{ item.product.title | escape }}"
                      >
                      <button class="cart-item__qty-btn" type="button" data-cart-qty-increase aria-label="Aumentar quantidade">
                        <span class="material-symbols-outlined text-base">add</span>
                      </button>
                    </div>
                  </div>
                  <button class="cart-item__remove" type="button" data-cart-remove>
                    <span class="material-symbols-outlined text-[16px]">delete</span>
                    <span>{{ section.settings.remove_label }}</span>
                  </button>
                </div>
              </div>
            </article>
          {% endfor %}
          </div>

          <aside class="cart-card cart-summary" aria-label="Resumo do pedido">
            <h2 class="cart-summary__title font-semibold">{{ section.settings.summary_title }}</h2>
            <div class="cart-summary__row">
              <span>{{ section.settings.subtotal_label }}</span>
              <strong data-cart-subtotal>{{ cart.items_subtotal_price | money }}</strong>
            </div>
            <div class="cart-summary__row">
              <span>{{ section.settings.shipping_label }}</span>
              <span>{{ section.settings.shipping_value }}</span>
            </div>
            <div class="cart-summary__row cart-summary__row--total">
              <span>{{ section.settings.total_label }}</span>
              <strong data-cart-total>{{ cart.total_price | money }}</strong>
            </div>

            <div class="cart-summary__actions">
              <a class="cart-btn cart-btn--primary" href="/pages/agendamento" data-cart-checkout>Finalizar pedido</a>
              <a class="cart-btn cart-btn--secondary" href="{{ routes.all_products_collection_url }}">{{ section.settings.keep_shopping_label }}</a>
            </div>
          </aside>
        </div>

        <div class="cart-mobile-checkout" data-cart-mobile-checkout>
          <div class="cart-mobile-checkout__inner">
            <div class="cart-mobile-checkout__meta">
              <p class="cart-mobile-checkout__label">{{ section.settings.total_label }}</p>
              <p class="cart-mobile-checkout__total" data-cart-total-mobile>{{ cart.total_price | money }}</p>
            </div>
            <a class="cart-btn cart-btn--primary cart-mobile-checkout__button" href="/pages/agendamento" data-cart-checkout>Finalizar pedido</a>
          </div>
        </div>
      </form>
    {% endif %}
    </div>
    <div data-cart-empty-state{% if cart.item_count > 0 %} style="display:none"{% endif %}>
      <div class="cart-card cart-empty">
        <h1 class="cart-empty__title font-semibold">{{ section.settings.empty_title }}</h1>
        <p class="cart-empty__text">{{ section.settings.empty_text }}</p>
        <p class="cart-empty__helper">{{ section.settings.empty_helper_text }}</p>
        <div class="cart-summary__actions" style="max-width: 320px; margin: 1rem auto 0;">
          <a class="cart-btn cart-btn--primary" href="{{ routes.all_products_collection_url }}">{{ section.settings.keep_shopping_label }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.CartConfig = { currencyCode: '{{ cart.currency.iso_code | escape }}' };
</script>
<script src="{{ 'cart.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Carrinho customizado",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Seu carrinho"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Confira os itens antes de finalizar sua compra"
    },
    {
      "type": "text",
      "id": "summary_title",
      "label": "Título do resumo",
      "default": "Resumo do pedido"
    },
    {
      "type": "text",
      "id": "quantity_label",
      "label": "Label de quantidade",
      "default": "Qtd"
    },
    {
      "type": "text",
      "id": "remove_label",
      "label": "Label remover",
      "default": "Remover"
    },
    {
      "type": "text",
      "id": "subtotal_label",
      "label": "Label subtotal",
      "default": "Subtotal"
    },
    {
      "type": "text",
      "id": "shipping_label",
      "label": "Label frete",
      "default": "Frete"
    },
    {
      "type": "text",
      "id": "shipping_value",
      "label": "Valor frete",
      "default": "Calculado no checkout"
    },
    {
      "type": "text",
      "id": "total_label",
      "label": "Label total",
      "default": "Total"
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Texto botão finalizar",
      "default": "Finalizar compra"
    },
    {
      "type": "text",
      "id": "keep_shopping_label",
      "label": "Texto botão continuar comprando",
      "default": "Continuar comprando"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Título carrinho vazio",
      "default": "Seu carrinho está vazio"
    },
    {
      "type": "text",
