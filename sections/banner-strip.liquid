{% liquid
  assign img_desktop = section.settings.image_desktop
  assign img_mobile  = section.settings.image_mobile
  assign link        = section.settings.link
  assign fit         = section.settings.image_fit | default: 'cover'
  assign is_full     = false
  if section.settings.layout_width == 'full'
    assign is_full = true
  endif
  assign radius = section.settings.border_radius | default: 0
  if is_full
    assign radius = 0
  endif

  assign bg_img_desktop = ''
  assign bg_img_mobile  = ''
  if img_desktop != blank
    assign bg_img_desktop = img_desktop | image_url: width: 1920
  endif
  if img_mobile != blank
    assign bg_img_mobile = img_mobile | image_url: width: 800
  endif
%}

<style>
  #shopify-section-{{ section.id }} .banner-strip__shell {
    height: {{ section.settings.height_mobile | default: 120 }}px;
    border-radius: {{ radius }}px;
    overflow: hidden;
    display: block;
    position: relative;
    background-color: {{ section.settings.bg_color | default: '#f0f0f0' }};
    {% if bg_img_mobile != blank %}
      background-image: url('{{ bg_img_mobile }}');
    {% elsif bg_img_desktop != blank %}
      background-image: url('{{ bg_img_desktop }}');
    {% endif %}
    background-size: {{ fit }};
    background-position: center center;
    background-repeat: no-repeat;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .banner-strip__shell {
      height: {{ section.settings.height_desktop | default: 180 }}px;
      {% if bg_img_desktop != blank %}
        background-image: url('{{ bg_img_desktop }}');
      {% endif %}
    }
  }
</style>

<div
  id="shopify-section-{{ section.id }}"
  class="banner-strip-section{% unless is_full %} section-layout-py{% endunless %}"
>
  <div class="{% if is_full %}w-full{% else %}max-w-[1440px] mx-auto px-4 md:px-6{% endif %}">

    {% if link != blank %}
      <a href="{{ link }}" class="banner-strip__shell" aria-label="{{ section.settings.aria_label | default: 'Banner' }}"></a>
    {% else %}
      <div class="banner-strip__shell"></div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Banner Faixa",
  "settings": [
    {
      "type": "header",
      "content": "Imagem"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Imagem (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Imagem (mobile)",
      "info": "Opcional. Se vazio, usa a imagem desktop."
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Ajuste da imagem",
      "options": [
        { "value": "cover",   "label": "Preencher (cover)"  },
        { "value": "contain", "label": "Conter (contain)" }
      ],
      "default": "cover"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link ao clicar"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Descrição acessível (alt / aria-label)",
      "default": "Banner"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_width",
      "label": "Largura",
      "options": [
        { "value": "contained", "label": "Contida (max 1440px)" },
        { "value": "full",      "label": "Full width"           }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 10, "max": 240, "step": 5, "unit": "px",
      "label": "Altura (mobile)",
      "default": 120
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 10, "max": 240, "step": 5, "unit": "px",
      "label": "Altura (desktop)",
      "default": 180
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0, "max": 32, "step": 2, "unit": "px",
      "label": "Arredondamento (ignorado em full width)",
      "default": 0
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo (fallback sem imagem)",
      "default": "#f0f0f0"
    }
  ],
  "presets": [
    {
      "name": "Banner Faixa",
      "category": "Imagem"
    }
  ]
}
{% endschema %}
