          <button class="pp-thumb rounded-lg overflow-hidden border-2 {% if forloop.first %}border-primary{% else %}border-transparent{% endif %} bg-white flex-shrink-0" type="button" data-product-thumb data-media-id="{{ media.id }}" data-media-url="{{ media | image_url: width: 1400 }}">
