      {% assign desktop_discount_percent = 0 %}
      {% if desktop_compare_price > current_variant.price and desktop_compare_price > 0 %}
        {% assign desktop_has_discount = true %}
        {% assign desktop_discount_percent = desktop_compare_price | minus: current_variant.price | times: 100.0 | divided_by: desktop_compare_price | round %}
      {% endif %}
      <div class="space-y-2">
        <div class="flex items-center gap-2" data-desktop-compare-row {% unless desktop_has_discount %}style="display:none;"{% endunless %}>
