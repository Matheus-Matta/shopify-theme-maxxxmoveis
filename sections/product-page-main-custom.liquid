          <h3 class="text-sm font-bold pp-text">Personalize sua compra</h3>
          {% for option in product.options_with_values %}
            <div class="space-y-2">
              <p class="text-sm pp-muted">{{ option.name }}: <span class="font-bold pp-text" data-option-current="{{ forloop.index0 }}">{{ option.selected_value }}</span></p>
              <div class="flex flex-wrap gap-2">
                {% for value in option.values %}
                  <button
                    class="pp-variant-option px-3 py-2 rounded-full text-sm {% if option.selected_value == value %}is-active{% endif %}"
                    type="button"
                    data-variant-option
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-option-value="{{ value | escape }}"
                  >{{ value }}</button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      <p class="text-sm pp-muted" data-variant-sku-row{% if current_variant.sku == blank %} style="display:none;"{% endif %}>SKU: <span class="font-bold pp-text" data-variant-sku>{{ current_variant.sku }}</span></p>

      <div>
        {% assign mobile_compare_price = current_variant.compare_at_price | default: 0 %}
        {% assign mobile_has_discount = false %}
        {% assign mobile_discount_percent = 0 %}
        {% if mobile_compare_price > current_variant.price and mobile_compare_price > 0 %}
          {% assign mobile_has_discount = true %}
          {% assign mobile_discount_percent = mobile_compare_price | minus: current_variant.price | times: 100.0 | divided_by: mobile_compare_price | round %}
        {% endif %}
        <div class="flex items-center mt-1" data-mobile-discount-row {% unless mobile_has_discount %}style="display:none;"{% endunless %}>
          <span class="pp-compare line-through font-medium" data-mobile-compare>{{ mobile_compare_price | money }}</span>
        </div>
        <div class="flex items-center mt-1">
          <span class="pp-mobile-price-currency text-lg font-bold"{% if mobile_has_discount %} style="color: var(--color-promo-final-price)"{% endif %}>R$</span>
          <span class="pp-mobile-price-major ml-1 font-headline font-black" data-mobile-price-major{% if mobile_has_discount %} style="color: var(--color-promo-final-price)"{% endif %}>{{ current_variant.price | money_without_currency | split: ',' | first }}</span>
          <span class="pp-mobile-price-minor text-lg font-bold" data-mobile-price-minor{% if mobile_has_discount %} style="color: var(--color-promo-final-price)"{% endif %}>,{{ current_variant.price | money_without_currency | split: ',' | last }}</span>
          <span class="pp-inline-discount-badge ml-2" data-mobile-discount {% unless mobile_has_discount %}style="display:none;"{% endunless %}>-{{ mobile_discount_percent }}%</span>
        </div>
        <p class="text-sm font-medium pp-muted mt-1" data-mobile-installment>ou ate {{ global_installments_count }}x {{ current_variant.price | divided_by: global_installments_count | money }} sem juros</p>
      </div>

      <div>
        <div class="flex items-center gap-2 text-sm font-medium">
          <span class="material-symbols-outlined pp-info-icon-primary text-lg" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
          <span><span data-sold-count>{{ sold_count }}</span> <span data-sold-label>{% if sold_count == 1 %}vendido{% else %}vendidos{% endif %}</span> nas ultimas 24 horas</span>
        </div>
        <div class="flex items-center gap-2 text-sm font-medium">
          <span class="material-symbols-outlined pp-info-icon-secondary text-lg" style="font-variation-settings: 'FILL' 1;">visibility</span>
          <span><span data-live-viewers>{{ live_viewers }}</span> <span data-live-viewers-label>{% if live_viewers == 1 %}pessoa esta{% else %}pessoas estao{% endif %}</span> vendo isso agora</span>
        </div>
      </div>

      {% if section.settings.enable_shipping_calculator %}
        <section class="pp-shipping-calc" data-shipping-calc data-shipping-country="{{ section.settings.shipping_calc_country }}" data-shipping-province="{{ section.settings.shipping_calc_province }}">
          <div class="flex items-center gap-2 my-3">
            <span class="material-symbols-outlined pp-shipping-calc-icon">{{ section.settings.shipping_calc_icon }}</span>
            <h3 class="font-bold pp-shipping-calc-title">{{ section.settings.shipping_calc_title }}</h3>
          </div>
          <div class="flex gap-2">
            <input class="pp-shipping-calc-input w-full px-4 py-3 outline-none" placeholder="{{ section.settings.shipping_calc_placeholder }}" type="text" inputmode="numeric" maxlength="9" data-shipping-cep>
            <button class="pp-shipping-calc-button px-6 py-3 font-bold active:scale-[0.98]" type="button" data-shipping-submit data-label-default="{{ section.settings.shipping_calc_button_label | escape }}" data-label-loading="{{ section.settings.shipping_calc_button_loading_label | escape }}">{{ section.settings.shipping_calc_button_label }}</button>
          </div>
          <div class="mt-3 pp-shipping-calc-feedback" data-shipping-feedback hidden></div>
          <div class="mt-3 pp-shipping-calc-rates" data-shipping-rates hidden></div>
        </section>
      {% endif %}
    </section>

    <section class="px-4 sm:px-5 pb-3 bg-surface-container-lowest">
      <div class="tpo-mobile-options" data-tpo-slot="mobile"></div>
      <div class="product-form__buttons flex flex-col gap-3" data-product-form-mobile>
        <div class="flex items-center gap-3">
          <label class="text-sm pp-muted shrink-0" for="qty-mobile-{{ section.id }}">Qtd.</label>
          <div class="pp-qty-box flex items-center border rounded-full px-2 min-w-[110px] justify-between">
            <button class="w-8 h-8 flex items-center justify-center pp-muted" type="button" data-qty-decrease><span class="material-symbols-outlined text-lg">remove</span></button>
            <input class="w-10 border-none bg-transparent text-center font-medium pp-text outline-none" id="qty-mobile-{{ section.id }}" type="text" inputmode="numeric" pattern="[0-9]*" value="1" data-qty-input aria-label="Quantidade">
            <button class="w-8 h-8 flex items-center justify-center pp-muted" type="button" data-qty-increase><span class="material-symbols-outlined text-lg">add</span></button>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <button id="ProductSubmitButton-{{ section.id }}" class="pp-add-cart-button product-form__submit w-full px-4 py-3 rounded-full inline-flex items-center justify-center gap-2" type="submit" name="add" data-action-add-cart data-variant-id="{{ current_variant.id }}" {% unless current_variant.available %}disabled{% endunless %}>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add_shopping_cart</span>
            <span>{{ section.settings.add_cart_btn_label }}</span>
