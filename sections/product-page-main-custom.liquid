    {% assign sticky_compare_price = current_variant.compare_at_price | default: 0 %}
    {% assign sticky_has_discount = false %}
    {% if sticky_compare_price > current_variant.price and sticky_compare_price > 0 %}
      {% assign sticky_has_discount = true %}
    {% endif %}

    <div class="pp-mobile-sticky-buy" data-sticky-buy-bar>
