        <div class="flex items-center gap-3">
          <span class="pp-price font-extrabold font-headline" data-desktop-price{% if desktop_has_discount %} style="color: var(--color-promo-final-price)"{% endif %}>{{ current_variant.price | money }}</span>
          <span class="pp-inline-discount-badge" data-desktop-discount {% unless desktop_has_discount %}style="display:none;"{% endunless %}>-{{ desktop_discount_percent }}%</span>
        </div>
