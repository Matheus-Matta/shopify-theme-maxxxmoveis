        </div>
        <div class="pp-mobile-sticky-btn-col pr-2">
          <button class="pp-buy-button pp-mobile-sticky-buy-btn w-full font-medium uppercase tracking-wide whitespace-nowrap" type="button" data-sticky-buy-button {% unless current_variant.available %}disabled{% endunless %} {% unless current_variant.available %}hidden{% endunless %}>{{ section.settings.buy_btn_label }}</button>
          <div class="pp-soldout-badge rounded-xl px-4 py-3 text-center font-black uppercase tracking-wide text-sm w-full" data-soldout-badge data-sticky-soldout-badge {% if current_variant.available %}style="display:none;"{% else %}style="display:block;"{% endif %}>Esgotado</div>
        </div>
        </div>
      </div>
