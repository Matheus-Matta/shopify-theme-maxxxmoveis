        {% if section.settings.enable_shipping_calculator %}
          <section class="pp-shipping-calc" data-shipping-calc data-shipping-country="{{ section.settings.shipping_calc_country }}" data-shipping-province="{{ section.settings.shipping_calc_province }}">
            <div class="flex items-center gap-2 my-3">
              <span class="material-symbols-outlined pp-shipping-calc-icon">{{ section.settings.shipping_calc_icon }}</span>
              <h3 class="font-bold pp-shipping-calc-title">{{ section.settings.shipping_calc_title }}</h3>
            </div>
            <div class="flex gap-2">
              <input class="pp-shipping-calc-input w-full px-4 py-3 outline-none" placeholder="{{ section.settings.shipping_calc_placeholder }}" type="text" inputmode="numeric" maxlength="9" data-shipping-cep>
              <button class="pp-shipping-calc-button px-6 py-3 font-bold active:scale-[0.98]" type="button" data-shipping-submit data-label-default="{{ section.settings.shipping_calc_button_label | escape }}" data-label-loading="{{ section.settings.shipping_calc_button_loading_label | escape }}">{{ section.settings.shipping_calc_button_label }}</button>
            </div>
            <div class="mt-3 pp-shipping-calc-feedback" data-shipping-feedback hidden></div>
            <div class="mt-3 pp-shipping-calc-rates" data-shipping-rates hidden></div>
          </section>
        {% endif %}

        <div class="space-y-3">
          <div id="tpo-extra-options" data-tpo-slot="desktop"></div>
          <div class="flex gap-2 items-stretch">
            <div class="pp-qty-box flex items-center border rounded-lg">
              <button class="px-4 py-2 pp-muted hover:text-primary transition-colors" type="button" data-qty-decrease><span class="material-symbols-outlined text-lg">remove</span></button>
              <input class="w-10 border-none bg-transparent text-center font-medium outline-none" type="text" inputmode="numeric" pattern="[0-9]*" name="quantity" value="1" data-qty-input aria-label="Quantidade">
              <button class="px-4 py-2 pp-muted hover:text-primary transition-colors" type="button" data-qty-increase><span class="material-symbols-outlined text-lg">add</span></button>
            </div>
            <button id="ProductSubmitButton-desktop-{{ section.id }}" class="pp-add-cart-button product-form__submit flex-1 px-5 shadow-sm transition-all active:scale-[0.98] inline-flex items-center justify-center gap-2" type="submit" name="add" data-action-add-cart data-variant-id="{{ current_variant.id }}" aria-label="Adicionar ao carrinho" title="Adicionar ao carrinho" {% unless current_variant.available %}disabled{% endunless %}>
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add_shopping_cart</span>
              <span>{{ section.settings.add_cart_btn_label }}</span>
            </button>
          </div>
          {%- if section.settings.show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- else -%}
            <label for="ProductSubmitButton-desktop-{{ section.id }}" class="pp-buy-button w-full py-4 font-medium shadow-lg transition-all active:scale-[0.98] uppercase tracking-wide flex items-center justify-center cursor-pointer" data-action-buy-cart onclick="(function(){var atc=document.getElementById('ProductSubmitButton-desktop-{{ section.id }}');if(atc&&!atc.disabled){setTimeout(function(){window.location.href='{{ routes.cart_url }}'},{{ section.settings.buy_btn_redirect_delay }})}})()" {% unless current_variant.available %}style="opacity:0.5;pointer-events:none;"{% endunless %}>{{ section.settings.buy_btn_label }}</label>
          {%- endif -%}
        </div>
        <div class="pp-soldout-badge rounded-xl px-4 py-3 text-center font-black uppercase tracking-wide text-sm" data-soldout-badge>Esgotado</div>
      </div>
      {%- endform -%}
    </div>
  </div>
</section>

<div class="pp-lightbox" data-lightbox aria-hidden="true">
  <button class="pp-lightbox-close" type="button" data-lightbox-close aria-label="Fechar imagem em tela cheia">
    <span class="material-symbols-outlined">close</span>
  </button>
  <button class="pp-lightbox-nav pp-lightbox-nav--prev" type="button" data-lightbox-prev aria-label="Imagem anterior">
    <span class="material-symbols-outlined">chevron_left</span>
  </button>
  <button class="pp-lightbox-nav pp-lightbox-nav--next" type="button" data-lightbox-next aria-label="PrÃ³xima imagem">
    <span class="material-symbols-outlined">chevron_right</span>
  </button>
  <div class="pp-lightbox-counter" data-lightbox-counter>1 / 1</div>
  <img class="pp-lightbox-image" data-lightbox-image src="{{ product.featured_image | image_url: width: 1200 }}" width="1200" height="1200" alt="Imagem ampliada do produto">
  <div class="pp-lightbox-zoom-controls" aria-label="Controles de zoom">
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-zoom-out aria-label="Diminuir zoom">
      <span class="material-symbols-outlined">remove</span>
    </button>
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-zoom-reset aria-label="Resetar zoom">
      <span class="material-symbols-outlined">fit_screen</span>
    </button>
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-zoom-in aria-label="Aumentar zoom">
      <span class="material-symbols-outlined">add</span>
    </button>
    <span class="pp-lightbox-zoom-level" data-lightbox-zoom-level>100%</span>
  </div>
  <div class="pp-lightbox-mobile-toolbar" aria-label="Menu flutuante de imagem no mobile">
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-prev aria-label="Imagem anterior">
      <span class="material-symbols-outlined">chevron_left</span>
    </button>
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-zoom-out aria-label="Diminuir zoom">
      <span class="material-symbols-outlined">remove</span>
    </button>
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-zoom-reset aria-label="Resetar imagem">
      <span class="material-symbols-outlined">fit_screen</span>
    </button>
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-zoom-in aria-label="Aumentar zoom">
      <span class="material-symbols-outlined">add</span>
    </button>
    <button class="pp-lightbox-zoom-btn" type="button" data-lightbox-next aria-label="PrÃ³xima imagem">
      <span class="material-symbols-outlined">chevron_right</span>
    </button>
  </div>
</div>

<script type="application/json" data-product-variants-json>
  {{ product.variants | json }}
</script>

<script>
  window.ProductConfig = {
    sectionId:         '{{ section.id }}',
    buyBtnLabel:       {{ section.settings.buy_btn_label | json }},
    installmentsCount: {{ global_installments_count }},
    compareAtMaxCents: {{ product.compare_at_price_max | default: 0 }},
    defaultVariantId:  '{{ current_variant.id }}',
    selectedOptions:   ['{{ current_variant.option1 | escape }}', '{{ current_variant.option2 | escape }}', '{{ current_variant.option3 | escape }}'],
    shippingMessages: {
      invalidZip:   {{ section.settings.shipping_calc_invalid_cep_message | json }},
      noRates:      {{ section.settings.shipping_calc_no_rates_message | json }},
      genericError: {{ section.settings.shipping_calc_error_message | json }},
      emptyCart:    {{ section.settings.shipping_calc_empty_cart_message | json }}
    },
    cartUrl:   '{{ routes.cart_url }}',
    productId: '{{ product.id }}',
    soldSeed:  {{ sold_count }},
    liveSeed:  {{ live_viewers }}
  };
</script>
<script src="{{ 'product-page.js' | asset_url }}" defer></script>

{% schema %}
