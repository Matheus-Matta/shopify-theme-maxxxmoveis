{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign first_collection = product.collections.first
  assign product_media = product.media
  assign main_media = product.featured_media | default: product.media.first
  assign compare_price_size_mobile = section.settings.product_compare_size_mobile | default: section.settings.product_compare_size
  assign compare_price_size_desktop = section.settings.product_compare_size_desktop | default: section.settings.product_compare_size
  assign global_installments_count = settings.global_installments_count | default: 10 | plus: 0
  assign buy_btn_size_safe = section.settings.buy_btn_text_size | default: settings.global_button_primary_text_size | default: 14 | plus: 0
  assign add_cart_btn_size_safe = section.settings.add_cart_btn_text_size | default: 14 | plus: 0
  assign add_cart_btn_icon_size_safe = section.settings.cart_plus_btn_icon_size | default: 20 | plus: 0
  assign sticky_btn_text_size_safe = section.settings.sticky_btn_text_size | default: settings.global_button_primary_text_size | default: 14 | plus: 0
  assign shipping_calc_input_text_size_safe = section.settings.shipping_calc_input_text_size | default: 14 | plus: 0
  assign shipping_calc_button_text_size_safe = section.settings.shipping_btn_text_size | default: settings.global_button_primary_text_size | default: 14 | plus: 0

  if global_installments_count < 1
    assign global_installments_count = 1
  endif

  if add_cart_btn_size_safe > 14
    assign add_cart_btn_size_safe = 14
  endif
  if add_cart_btn_size_safe < 11
    assign add_cart_btn_size_safe = 11
  endif

  if add_cart_btn_icon_size_safe > 19
    assign add_cart_btn_icon_size_safe = 19
  endif
  if add_cart_btn_icon_size_safe < 16
    assign add_cart_btn_icon_size_safe = 16
  endif

  if shipping_calc_input_text_size_safe > 13
    assign shipping_calc_input_text_size_safe = 13
  endif
  if shipping_calc_input_text_size_safe < 11
    assign shipping_calc_input_text_size_safe = 11
  endif

  assign pp_form_id = 'pp-form-' | append: section.id
  assign sold_day_seed = 'now' | date: '%Y%m%d' | plus: 0
  assign sold_count = product.id | plus: sold_day_seed | modulo: 23 | plus: 14

  assign view_hour_seed = 'now' | date: '%Y%m%d%H' | plus: 0
  assign live_viewers = product.id | times: 3 | plus: view_hour_seed | modulo: 18 | plus: 7

  assign pp_text_color = settings.global_text_primary_color
  assign pp_muted_color = settings.global_text_muted_color
  assign pp_page_max_width = settings.global_layout_max_width | default: 1440
  assign pp_title_color = settings.global_primary_color
  assign pp_price_color = settings.global_text_primary_color
  assign pp_compare_color = settings.global_text_muted_color
  assign pp_discount_badge_bg = settings.global_product_card_discount_badge_bg | default: settings.global_danger_color | default: '#ef4444'
  assign pp_discount_badge_text = settings.global_product_card_discount_badge_text | default: '#ffffff'
  assign pp_icon_color = settings.global_primary_color
  assign pp_variant_selected_bg = settings.global_primary_soft_color | default: '#EAF3FF'
  assign pp_variant_selected_text = settings.global_primary_color
  assign pp_variant_selected_border = settings.global_primary_color
  assign pp_variant_unselected_bg = settings.global_button_secondary_bg_color | default: '#ffffff'
  assign pp_variant_unselected_text = settings.global_text_primary_color
  assign pp_variant_unselected_border = settings.global_border_strong_color | default: '#D1D5DB'
  assign pp_buy_btn_bg = section.settings.buy_btn_bg | default: settings.global_button_primary_bg_color
  assign pp_buy_btn_bg_hover = section.settings.buy_btn_bg_hover | default: settings.global_button_primary_bg_hover_color | default: '#004A9D'
  assign pp_buy_btn_text = section.settings.buy_btn_text | default: settings.global_button_primary_text_color | default: '#ffffff'
  assign pp_buy_btn_radius = section.settings.buy_btn_radius | default: settings.global_button_primary_radius | default: 12
  assign pp_cart_btn_bg = section.settings.cart_btn_bg | default: settings.global_button_secondary_bg_color | default: '#ffffff'
  assign pp_cart_btn_bg_hover = section.settings.cart_btn_bg_hover | default: settings.global_button_secondary_bg_hover_color | default: '#F7F7F7'
  assign pp_cart_btn_border = section.settings.cart_btn_border | default: settings.global_button_secondary_border_color | default: '#E5E7EB'
  assign pp_cart_btn_text = section.settings.cart_btn_text | default: settings.global_primary_color
  assign pp_qty_bg = settings.global_button_secondary_bg_color | default: '#ffffff'
  assign pp_qty_border = settings.global_border_color
  assign pp_sticky_price_color = settings.global_text_primary_color
  assign pp_sticky_compare_color = settings.global_text_muted_color
  assign pp_sticky_btn_bg = section.settings.sticky_btn_bg | default: settings.global_button_primary_bg_color
  assign pp_sticky_btn_bg_hover = section.settings.sticky_btn_bg_hover | default: settings.global_button_primary_bg_hover_color | default: '#004A9D'
  assign pp_sticky_btn_text = section.settings.sticky_btn_text | default: settings.global_button_primary_text_color | default: '#ffffff'
  assign pp_sticky_btn_radius = section.settings.sticky_btn_radius | default: settings.global_button_primary_radius | default: 12
  assign pp_shipping_icon = settings.global_primary_color
  assign pp_shipping_title = settings.global_text_primary_color
  assign pp_shipping_input_border = settings.global_border_color
  assign pp_shipping_input_text = settings.global_text_primary_color
  assign pp_shipping_btn_bg = section.settings.shipping_btn_bg | default: settings.global_button_primary_bg_color
  assign pp_shipping_btn_bg_hover = section.settings.shipping_btn_bg_hover | default: settings.global_button_primary_bg_hover_color | default: '#004A9D'
  assign pp_shipping_btn_text = section.settings.shipping_btn_text | default: settings.global_button_primary_text_color | default: '#ffffff'
  assign pp_shipping_result_border = settings.global_border_color
  assign pp_shipping_error = settings.global_danger_color | default: '#ef4444'
%}

<style>
  #shopify-section-{{ section.id }} .pp-text { color: {{ pp_text_color }}; }
  #shopify-section-{{ section.id }} .pp-muted { color: {{ pp_muted_color }}; }
  #shopify-section-{{ section.id }} .pp-breadcrumb {
    font-size: {{ section.settings.breadcrumb_size }}px;
    color: {{ section.settings.breadcrumb_color }};
  }
  #shopify-section-{{ section.id }} .pp-breadcrumb a:hover { color: {{ section.settings.breadcrumb_hover_color }}; }
  #shopify-section-{{ section.id }} .pp-breadcrumb-sep { color: {{ section.settings.breadcrumb_separator_color }}; }
  #shopify-section-{{ section.id }} .pp-media-main {
    width: 100%;
    background-repeat: no-repeat;
    background-position: {{ section.settings.main_image_position }};
    background-size: {{ section.settings.main_image_size }};
  }
  #shopify-section-{{ section.id }} .pp-thumb {
    width: {{ section.settings.thumb_size }}px;
    height: {{ section.settings.thumb_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-title {
    color: {{ pp_title_color }};
    font-size: {{ section.settings.product_title_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-price {
    color: {{ pp_price_color }};
    font-size: {{ section.settings.product_price_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-compare {
    color: var(--color-promo-old-price);
    font-size: {{ compare_price_size_mobile }}px;
  }
  #shopify-section-{{ section.id }} .pp-info-icon-primary { color: {{ pp_icon_color }}; }
  #shopify-section-{{ section.id }} .pp-info-icon-secondary { color: {{ pp_icon_color }}; }
  #shopify-section-{{ section.id }} .pp-buy-button {
    background-color: {{ pp_buy_btn_bg }};
    color: {{ pp_buy_btn_text }};
    border-radius: {{ pp_buy_btn_radius }}px;
    font-size: {{ buy_btn_size_safe }}px;
    font-weight: 500;
    line-height: 1.15;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .pp-buy-button:disabled { cursor: not-allowed; }
  #shopify-section-{{ section.id }} .pp-buy-button:hover { background-color: {{ pp_buy_btn_bg_hover }}; }
  #shopify-section-{{ section.id }} .pp-add-cart-button {
    min-height: {{ section.settings.cart_plus_btn_size }}px;
    background-color: {{ pp_cart_btn_bg }};
    color: {{ pp_cart_btn_text }};
    border-radius: {{ section.settings.cart_plus_btn_radius }}px;
    border: 1px solid {{ pp_cart_btn_border }};
    font-size: {{ add_cart_btn_size_safe }}px;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.15;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .pp-add-cart-button:disabled { cursor: not-allowed; }
  #shopify-section-{{ section.id }} .pp-add-cart-button .material-symbols-outlined {
    font-size: {{ add_cart_btn_icon_size_safe }}px;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .pp-add-cart-button:hover {
    background-color: {{ pp_cart_btn_bg_hover }};
  }
  #shopify-section-{{ section.id }} .pp-qty-box {
    background-color: {{ pp_qty_bg }};
    border-color: {{ pp_qty_border }};
    border-radius: {{ section.settings.qty_radius }}px;
    min-height: {{ section.settings.cart_plus_btn_size }}px;
    transition: box-shadow 220ms ease, transform 220ms ease, border-color 220ms ease;
  }
  #shopify-section-{{ section.id }} [data-product-form].is-cart-added .pp-qty-box {
    border-color: {{ pp_cart_btn_text }};
    box-shadow: 0 0 0 3px color-mix(in srgb, {{ pp_cart_btn_text }} 22%, transparent);
    transform: translateY(-1px);
  }
  #shopify-section-{{ section.id }} [data-product-form].is-cart-added [data-action-add-cart] {
    box-shadow: 0 10px 24px color-mix(in srgb, {{ pp_cart_btn_text }} 24%, transparent);
  }
  #shopify-section-{{ section.id }} [data-action-add-cart].is-cart-added {
    background-color: {{ pp_cart_btn_bg_hover }};
    box-shadow: 0 8px 20px color-mix(in srgb, {{ pp_cart_btn_text }} 30%, transparent);
    animation: ppAtcPop 480ms cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes ppAtcPop {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.08); }
    65%  { transform: scale(0.96); }
    100% { transform: scale(1); }
  }
  #shopify-section-{{ section.id }} .pp-mobile-media-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #shopify-section-{{ section.id }} .pp-mobile-media-track::-webkit-scrollbar {
    display: none;
  }
  #shopify-section-{{ section.id }} .pp-mobile-dot {
    transition: width 180ms ease, background-color 180ms ease;
  }
  #shopify-section-{{ section.id }} .pp-mobile-dot.is-active {
    width: 2rem;
    background-color: {{ pp_icon_color }};
  }
  #shopify-section-{{ section.id }} .pp-mobile-thumb {
    border: 1px solid #d7d7d7;
  }
  #shopify-section-{{ section.id }} .pp-mobile-thumb.is-active {
    border-color: {{ pp_icon_color }};
    box-shadow: 0 0 0 1px {{ pp_icon_color }} inset;
  }
  #shopify-section-{{ section.id }} .pp-main-media-shell {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: zoom-in;
  }
  #shopify-section-{{ section.id }} .pp-main-media-hint {
    position: absolute;
    right: 12px;
    bottom: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.52);
    color: #ffffff;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.01em;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 180ms ease, transform 180ms ease;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .pp-main-media-shell::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.18), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 180ms ease;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .pp-main-media-shell:hover::after {
    opacity: 1;
  }
  #shopify-section-{{ section.id }} .pp-main-media-shell:hover .pp-main-media-hint {
    opacity: 1;
    transform: translateY(0);
  }
  #shopify-section-{{ section.id }} .pp-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(10, 10, 12, 0.66);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  #shopify-section-{{ section.id }} .pp-lightbox.is-open {
    display: flex;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-image {
    max-width: min(94vw, 1680px);
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 14px;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.45);
    background: #ffffff;
    transform-origin: center center;
    transition: transform 140ms ease;
    will-change: transform;
    touch-action: none;
    cursor: zoom-in;
    user-select: none;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2147483001;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    background: rgba(0, 0, 0, 0.34);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-counter {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2147483001;
    min-width: 78px;
    height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.34);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.24);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2147483001;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    background: rgba(0, 0, 0, 0.34);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 160ms ease, background-color 160ms ease;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-nav:hover {
    background: rgba(0, 0, 0, 0.46);
  }
  #shopify-section-{{ section.id }} .pp-lightbox-nav:disabled {
    opacity: 0.38;
    cursor: not-allowed;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-nav--prev {
    left: 18px;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-nav--next {
    right: 18px;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-zoom-controls {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2147483001;
    display: inline-flex;
    gap: 8px;
    padding: 8px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.34);
    border: 1px solid rgba(255, 255, 255, 0.26);
  }
  #shopify-section-{{ section.id }} .pp-lightbox-zoom-btn {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.36);
    background: rgba(0, 0, 0, 0.34);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-zoom-level {
    min-width: 56px;
    color: #ffffff;
    font-size: 12px;
    font-weight: 400;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .pp-lightbox-mobile-toolbar {
    display: none;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .pp-lightbox {
      padding: 12px 10px 96px;
      align-items: flex-start;
      justify-content: center;
    }
    #shopify-section-{{ section.id }} .pp-lightbox-image {
      margin-top: 54px;
      max-width: calc(100vw - 20px);
      max-height: calc(100vh - 180px);
      border-radius: 12px;
    }
    #shopify-section-{{ section.id }} .pp-lightbox-close {
      top: 10px;
      right: 10px;
      width: 38px;
      height: 38px;
    }
    #shopify-section-{{ section.id }} .pp-lightbox-counter {
      top: 12px;
      left: 12px;
      transform: none;
      min-width: 68px;
      height: 30px;
      font-size: 11px;
      justify-content: center;
      padding: 0 10px;
    }
    #shopify-section-{{ section.id }} .pp-lightbox-nav,
    #shopify-section-{{ section.id }} .pp-lightbox-zoom-controls {
      display: none;
    }
    #shopify-section-{{ section.id }} .pp-lightbox-mobile-toolbar {
      position: absolute;
      left: 10px;
      right: 10px;
      bottom: calc(10px + env(safe-area-inset-bottom));
      z-index: 2147483001;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 8px;
      padding: 10px;
      border-radius: 14px;
      background: rgba(0, 0, 0, 0.38);
      border: 1px solid rgba(255, 255, 255, 0.26);
    }
    #shopify-section-{{ section.id }} .pp-lightbox-mobile-toolbar .pp-lightbox-zoom-btn {
      width: 38px;
      height: 38px;
      margin: 0 auto;
      border-radius: 999px;
      border-color: rgba(255, 255, 255, 0.36);
      background: rgba(0, 0, 0, 0.34);
    }
  }
  #shopify-section-{{ section.id }} .pp-mobile-title {
    color: {{ section.settings.mobile_title_color }};
    font-size: {{ section.settings.mobile_title_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-mobile-price-major,
  #shopify-section-{{ section.id }} .pp-mobile-price-minor,
  #shopify-section-{{ section.id }} .pp-mobile-price-currency {
    color: {{ section.settings.mobile_price_color }};
  }
  #shopify-section-{{ section.id }} .pp-mobile-price-major {
    font-size: {{ section.settings.mobile_price_size }}px;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .pp-inline-discount-badge {
    background-color: {{ pp_discount_badge_bg }};
    color: {{ pp_discount_badge_text }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 400;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .pp-variant-option {
    border: 1px solid {{ pp_variant_unselected_border }};
    color: {{ pp_variant_unselected_text }};
    background-color: {{ pp_variant_unselected_bg }};
    transition: all 180ms ease;
  }
  #shopify-section-{{ section.id }} .pp-variant-option.is-active {
    border-color: {{ pp_variant_selected_border }};
    color: {{ pp_variant_selected_text }};
    background-color: {{ pp_variant_selected_bg }};
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-buy {
    --pp-sticky-safe-bottom: env(safe-area-inset-bottom);
    --pp-sticky-bottom-offset: 0px;
    position: fixed;
    left: 0;
    right: 0;
    bottom: var(--pp-sticky-bottom-offset);
    z-index: 2147482900;
    background: rgba(255, 255, 255, 0.97);
    border-top: 1px solid #E5E7EB;
    box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 10px 12px calc(10px + var(--pp-sticky-safe-bottom));
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px);
    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-inner {
    width: 100%;
    margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-row {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-price-col {
    flex: 0 0 50%;
    max-width: 50%;
    min-width: 0;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-btn-col {
    flex: 0 0 50%;
    max-width: 50%;
    min-width: 0;
    display: flex;
    justify-content: flex-end;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-buy.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-spacer {
    height: calc(86px + var(--pp-sticky-safe-bottom) + var(--pp-sticky-bottom-offset));
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-price {
    color: {{ pp_sticky_price_color }};
    font-size: {{ section.settings.sticky_price_size }}px;
    line-height: 1;
    font-weight: 400;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-compare {
    color: var(--color-promo-old-price);
    font-size: {{ section.settings.sticky_compare_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-installment {
    color: {{ pp_muted_color }};
    font-size: 12px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.1;
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-buy-btn {
    min-height: 44px;
    padding: 0 14px;
    font-size: {{ sticky_btn_text_size_safe }}px;
    border-radius: {{ pp_sticky_btn_radius }}px;
    background-color: {{ pp_sticky_btn_bg }};
    color: {{ pp_sticky_btn_text }};
  }
  #shopify-section-{{ section.id }} .pp-mobile-sticky-buy-btn:hover {
    background-color: {{ pp_sticky_btn_bg_hover }};
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc {
    background-color: {{ section.settings.shipping_calc_bg_color }};
    border-top: 1px solid {{ section.settings.shipping_calc_border_color }};
    margin-top: 0;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-icon {
    color: {{ pp_shipping_icon }};
    font-size: {{ section.settings.shipping_calc_icon_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-title {
    color: {{ pp_shipping_title }};
    font-size: {{ section.settings.shipping_calc_title_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-input {
    background-color: {{ section.settings.shipping_calc_input_bg_color }};
    border: 1px solid {{ pp_shipping_input_border }};
    color: {{ pp_shipping_input_text }};
    font-size: {{ shipping_calc_input_text_size_safe }}px;
    border-radius: {{ section.settings.shipping_calc_radius }}px;
    min-height: 38px;
    padding: 0.5rem 0.72rem;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-input::placeholder {
    color: {{ section.settings.shipping_calc_input_placeholder_color }};
    opacity: 1;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-input:focus {
    outline: none;
    border-color: {{ pp_shipping_btn_bg }};
    box-shadow: 0 0 0 3px color-mix(in srgb, {{ pp_shipping_btn_bg }} 24%, transparent);
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-button {
    background-color: {{ pp_shipping_btn_bg }};
    color: {{ pp_shipping_btn_text }};
    font-size: {{ shipping_calc_button_text_size_safe }}px;
    border-radius: {{ section.settings.shipping_calc_radius }}px;
    min-height: 38px;
    padding: 0.45rem 0.82rem;
    transition: transform 180ms ease, background-color 180ms ease, opacity 180ms ease;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-button:hover {
    background-color: {{ pp_shipping_btn_bg_hover }};
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-button:disabled {
    opacity: 0.75;
    cursor: wait;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-feedback {
    color: {{ section.settings.shipping_calc_result_text_color }};
    font-size: {{ section.settings.shipping_calc_result_text_size }}px;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-feedback:empty {
    display: none;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-feedback.is-error {
    color: {{ pp_shipping_error }};
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rates {
    display: grid;
    gap: 6px;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rates:empty {
    display: none;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rate {
    border: 1px solid {{ pp_shipping_result_border }};
    border-radius: {{ section.settings.shipping_calc_radius }}px;
    background: {{ section.settings.shipping_calc_result_bg_color }};
    padding: 9px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rate-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rate-name {
    color: {{ section.settings.shipping_calc_result_text_color }};
    font-size: {{ section.settings.shipping_calc_result_text_size }}px;
    font-weight: 400;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rate-meta {
    color: {{ muted_color }};
    font-size: calc({{ section.settings.shipping_calc_result_text_size }}px - 1px);
    line-height: 1.35;
  }
  #shopify-section-{{ section.id }} .pp-shipping-calc-rate-price {
    color: {{ section.settings.shipping_calc_price_color }};
    font-size: {{ section.settings.shipping_calc_result_text_size }}px;
    font-weight: 400;
    white-space: nowrap;
  }
  @media (max-width: 1023px) {
    body.pp-has-mobile-sticky-buy #shopify-section-footer .footer-shell {
      margin-bottom: var(--pp-sticky-footer-gap, 0px);
    }
  }
  #shopify-section-{{ section.id }} .pp-soldout-badge {
    display: none;
    border: 1px dashed {{ pp_buy_btn_bg }};
    color: {{ pp_buy_btn_bg }};
    background-color: color-mix(in srgb, {{ pp_buy_btn_bg }} 10%, #ffffff);
    animation: ppSoldOutPulse 1.4s ease-in-out infinite;
  }

  @keyframes ppSoldOutPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.72; transform: scale(0.985); }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .pp-mobile-sticky-buy,
    #shopify-section-{{ section.id }} .pp-mobile-sticky-spacer {
      display: none;
    }
    #shopify-section-{{ section.id }} .pp-media-main {
      aspect-ratio: 1;
      height: auto;
      max-height: 640px;
    }
    #shopify-section-{{ section.id }} .pp-compare {
      font-size: {{ compare_price_size_desktop }}px;
    }
  }
</style>

<section class="max-w-none mx-auto px-4 sm:px-5 md:px-6 py-2 sm:py-3 md:py-4 lg:py-4 pp-text" style="max-width: {{ pp_page_max_width }}px;">
  <nav class="pp-breadcrumb hidden lg:flex items-center gap-2 mb-4">
    <a class="transition-colors" href="{{ routes.root_url }}">Home</a>
    <span class="material-symbols-outlined text-xs pp-breadcrumb-sep">chevron_right</span>
    {% if first_collection %}
      <a class="transition-colors" href="{{ first_collection.url }}">{{ first_collection.title }}</a>
    {% else %}
      <a class="transition-colors" href="{{ routes.all_products_collection_url }}">Lancamentos</a>
    {% endif %}
    <span class="material-symbols-outlined text-xs pp-breadcrumb-sep">chevron_right</span>
    <span class="font-semibold">{{ product.title }}</span>
  </nav>

  {%- form 'product', product, id: pp_form_id, class: 'product-form shopify-product-form contents', novalidate: 'novalidate', data-product-form: '', data-type: 'add-to-cart-form' -%}
    <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" {% unless current_variant.available %}disabled{% endunless %}>
    <input type="hidden" name="return_to" value="{{ product.url }}" data-return-to>
    <script>(function(){var f=document.getElementById('{{ pp_form_id }}');if(f)f.target='pp-form-sink';}());</script>
  <div class="lg:hidden -mx-4 sm:-mx-5 md:-mx-6" data-mobile-pdp-root>
    <section class="relative bg-surface-container-lowest overflow-hidden">
      <div class="pp-mobile-media-track flex overflow-x-auto snap-x snap-mandatory aspect-square" data-mobile-media-track>
        {% for image in product.images limit: 10 %}
          <div class="flex-none w-full snap-start" data-mobile-slide data-image-id="{{ image.id }}">
            {{ image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: product.title }}
          </div>
        {% else %}
          <div class="flex-none w-full snap-start" data-mobile-slide>
            {{ product.featured_image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: product.title }}
          </div>
        {% endfor %}
      </div>

      <div class="absolute top-4 left-4 bg-black/40 backdrop-blur-sm text-white px-2 py-1 rounded-full text-[10px] font-bold" style="margin-top: 4px;">
        <span data-mobile-media-count-current>1</span>/{% if product.images.size > 0 %}{{ product.images.size | at_most: 10 }}{% else %}1{% endif %}
      </div>

      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1 items-center">
        {% for image in product.images limit: 10 %}
          <span class="pp-mobile-dot w-4 h-1 rounded-full {% if forloop.first %}is-active{% else %}bg-surface-container-highest{% endif %}" data-mobile-dot></span>
        {% else %}
          <span class="pp-mobile-dot w-4 h-1 rounded-full is-active" data-mobile-dot></span>
        {% endfor %}
      </div>
    </section>

    <div class="px-4 sm:px-5 pt-3 sm:pt-4 bg-surface-container-lowest">
      <div class="flex gap-2 overflow-x-auto pp-mobile-media-track" data-mobile-thumbs>
        {% for image in product.images limit: 10 %}
          <button class="pp-mobile-thumb {% if forloop.first %}is-active{% endif %} w-16 h-16 rounded-lg overflow-hidden shrink-0 bg-white" type="button" data-mobile-thumb data-image-id="{{ image.id }}" data-mobile-thumb-index="{{ forloop.index0 }}" aria-label="Imagem {{ forloop.index }}">
            {{ image | image_url: width: 180 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: product.title }}
          </button>
        {% else %}
          <button class="pp-mobile-thumb is-active w-16 h-16 rounded-lg overflow-hidden shrink-0 bg-white" type="button" data-mobile-thumb data-mobile-thumb-index="0" aria-label="Imagem principal">
            {{ product.featured_image | image_url: width: 180 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: product.title }}
          </button>
        {% endfor %}
      </div>
    </div>

    <section class="px-4 sm:px-5 py-4 sm:py-5 md:pt-6 bg-surface-container-lowest flex flex-col gap-4">
