{% liquid
  assign section_bg = settings.surface_card_color
  assign section_text = settings.text_color
  assign section_border = settings.border_color
  assign panel_bg = settings.surface_color
  assign panel_border = settings.border_color
  assign label_color = settings.muted_color
  assign input_bg = settings.surface_card_color
  assign input_text = settings.text_color
  assign input_border = settings.border_color

  assign section_bg = section.settings.section_bg_color | default: section_bg
  assign section_text = section.settings.section_text_color | default: section_text
  assign section_border = section.settings.section_border_color | default: section_border
  assign panel_bg = section.settings.panel_bg_color | default: panel_bg
  assign panel_border = section.settings.panel_border_color | default: panel_border
  assign label_color = section.settings.label_color | default: label_color
  assign input_bg = section.settings.input_bg_color | default: input_bg
  assign input_text = section.settings.input_text_color | default: input_text
  assign input_border = section.settings.input_border_color | default: input_border

  assign emphasis_color = section.settings.title_emphasis_color | default: settings.global_primary_color
  assign description_color = section.settings.description_color | default: section_text
  assign privacy_color = section.settings.privacy_color | default: section_text
  assign button_bg = section.settings.button_bg_color | default: settings.global_button_primary_bg_color
  assign button_bg_hover = section.settings.button_bg_hover_color | default: settings.global_button_primary_bg_hover_color | default: '#004A9D'
  assign button_text = section.settings.button_text_color | default: settings.global_button_primary_text_color
%}

<style>
  #shopify-section-{{ section.id }} .newsletter-panel {
    border-radius: {{ section.settings.panel_radius_mobile }}px;
    padding: {{ section.settings.panel_padding_mobile }}px;
  }

  #shopify-section-{{ section.id }} .newsletter-heading {
    font-size: {{ section.settings.title_size_mobile }}px;
    line-height: 1.18;
  }

  #shopify-section-{{ section.id }} .newsletter-description {
    font-size: {{ section.settings.description_size_mobile }}px;
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .newsletter-input {
    border-width: 1px;
    border-style: solid;
  }

  #shopify-section-{{ section.id }} .newsletter-submit {
    background-color: var(--newsletter-button-bg);
    color: var(--newsletter-button-text);
    font-size: {{ section.settings.button_text_size_mobile }}px;
  }

  #shopify-section-{{ section.id }} .newsletter-submit:hover {
    background-color: var(--newsletter-button-bg-hover);
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .newsletter-panel {
      border-radius: {{ section.settings.panel_radius_desktop }}px;
      padding: {{ section.settings.panel_padding_desktop }}px;
    }

    #shopify-section-{{ section.id }} .newsletter-heading {
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    #shopify-section-{{ section.id }} .newsletter-description {
      font-size: {{ section.settings.description_size_desktop }}px;
    }

    #shopify-section-{{ section.id }} .newsletter-submit {
      font-size: {{ section.settings.button_text_size_desktop }}px;
    }
  }
</style>

<section class="w-full section-layout-py border-t" style="--section-bg: {{ section_bg }}; --section-text: {{ section_text }}; --section-border: {{ section_border }}; --newsletter-description-color: {{ description_color }}; --newsletter-privacy-color: {{ privacy_color }}; --newsletter-emphasis-color: {{ emphasis_color }}; --newsletter-button-bg: {{ button_bg }}; --newsletter-button-bg-hover: {{ button_bg_hover }}; --newsletter-button-text: {{ button_text }}; background-color: var(--section-bg); border-color: var(--section-border);">
  <div class="max-w-[1440px] mx-auto section-layout-px">
    <div class="newsletter-panel border shadow-sm" style="background-color: {{ panel_bg }}; border-color: {{ panel_border }};">
      <div class="flex flex-col lg:flex-row items-center gap-4 md:gap-6 lg:gap-8">
        <div class="lg:w-1/3 text-center lg:text-left">
          <h2 class="newsletter-heading font-headline font-black mb-4" style="color: var(--section-text);">{{ section.settings.title }} <span class="italic" style="color: var(--newsletter-emphasis-color);">{{ section.settings.title_emphasis }}</span></h2>
          <p class="newsletter-description font-medium" style="color: var(--newsletter-description-color);">{{ section.settings.text }}</p>
        </div>

        <div class="flex-1 w-full">
          {% capture newsletter_fields %}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold uppercase tracking-wider ml-1" style="color: {{ label_color }};" for="newsletter-name-{{ section.id }}">{{ section.settings.name_label }}</label>
                <input class="newsletter-input w-full rounded-xl py-3 px-4 focus:ring-2 focus:ring-primary focus:border-primary text-sm font-body" style="background-color: {{ input_bg }}; color: {{ input_text }}; border-color: {{ input_border }};" id="newsletter-name-{{ section.id }}" name="contact[first_name]" placeholder="{{ section.settings.name_placeholder }}" type="text" />
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold uppercase tracking-wider ml-1" style="color: {{ label_color }};" for="newsletter-email-{{ section.id }}">{{ section.settings.email_label }}</label>
                <input class="newsletter-input w-full rounded-xl py-3 px-4 focus:ring-2 focus:ring-primary focus:border-primary text-sm font-body" style="background-color: {{ input_bg }}; color: {{ input_text }}; border-color: {{ input_border }};" id="newsletter-email-{{ section.id }}" name="contact[email]" placeholder="{{ section.settings.email_placeholder }}" type="email" required />
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-xs font-bold uppercase tracking-wider ml-1" style="color: {{ label_color }};" for="newsletter-phone-{{ section.id }}">{{ section.settings.phone_label }}</label>
                <input class="newsletter-input w-full rounded-xl py-3 px-4 focus:ring-2 focus:ring-primary focus:border-primary text-sm font-body" style="background-color: {{ input_bg }}; color: {{ input_text }}; border-color: {{ input_border }};" id="newsletter-phone-{{ section.id }}" name="contact[phone]" placeholder="{{ section.settings.phone_placeholder }}" type="tel" />
              </div>
              <button class="newsletter-submit md:col-span-3 font-black py-4 rounded-xl transition-all shadow-lg shadow-primary/20 mt-4 md:mt-6 uppercase tracking-widest flex items-center justify-center gap-2" type="submit">
                <span class="material-symbols-outlined text-xl">send</span>
                {{ section.settings.button_label }}
              </button>
            </div>
          {% endcapture %}

          <div id="newsletter-section-{{ section.id }}">
            {% if section.settings.form_action_url != blank %}
              <form method="post" action="{{ section.settings.form_action_url }}">
                {{ newsletter_fields }}
              </form>
            {% else %}
              {% form 'customer' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                {{ newsletter_fields }}
              {% endform %}
            {% endif %}
          </div>
          <p class="text-[10px] mt-4 text-center lg:text-left" style="color: var(--newsletter-privacy-color);">{{ section.settings.privacy_text }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var nl = document.getElementById('newsletter-section-{{ section.id }}');
    if (!nl) return;
    var form = nl.querySelector('form');
    if (!form) return;

    // Injeta campos extras ocultos configurados via JSON
    var raw = {{ section.settings.extra_fields_json | default: '[]' | json }};
    var extraFields;
    try { extraFields = JSON.parse(raw); } catch (e) { extraFields = []; }

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      // Injeta campos extras antes de serializar
      if (Array.isArray(extraFields)) {
        extraFields.forEach(function (f) {
          if (!f.name) return;
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = f.name;
          input.value = f.value || '';
          form.appendChild(input);
        });
      }

      var submitBtn = form.querySelector('[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;

      var data = new FormData(form);
      fetch(form.action || window.location.pathname, {
        method: 'POST',
        body: data,
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        redirect: 'manual'
      }).then(function () {
        form.reset();
        if (submitBtn) {
          var original = submitBtn.innerHTML;
          submitBtn.innerHTML = '<span class="material-symbols-outlined text-xl">check_circle</span> Enviado!';
          setTimeout(function () {
            submitBtn.innerHTML = original;
            submitBtn.disabled = false;
          }, 4000);
        }
      }).catch(function () {
        if (submitBtn) submitBtn.disabled = false;
      });
    });
  })();
</script>

