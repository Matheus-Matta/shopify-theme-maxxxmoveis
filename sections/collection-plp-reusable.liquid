</style>

<section class="plp-shell section-layout-py" data-cards-per-row="{{ cards_per_row }}" data-card-width-desktop="{{ plp_card_width_desktop }}" data-grid-gap-desktop="{{ plp_gap_desktop }}" style="--gc-card-bg: {{ plp_card_bg }}; --gc-card-border: {{ plp_card_border }}; --gc-card-border-hover: {{ plp_card_border_hover }}; --gc-card-border-width: {{ plp_card_border_width }}px; --gc-card-radius: {{ plp_card_radius }}px; --gc-card-padding: {{ plp_card_padding }}px; --gc-card-height-mobile: {{ plp_card_height_mobile }}px; --gc-card-height-desktop: {{ plp_card_height_desktop }}px; --gc-media-height-mobile: {{ plp_media_height_mobile }}px; --gc-media-height-desktop: {{ plp_media_height_desktop }}px; --gc-image-fit: {{ plp_image_fit }}; --gc-image-position: {{ plp_image_position }}; --gc-meta-color: {{ plp_meta_color }}; --gc-price-color: {{ plp_price_color }}; --gc-meta-size-mobile: {{ plp_meta_size_mobile }}px; --gc-meta-size-desktop: {{ plp_meta_size_desktop }}px; --gc-price-size-mobile: {{ plp_price_size_mobile }}px; --gc-price-size-desktop: {{ plp_price_size_desktop }}px; --gc-buy-bg: {{ plp_buy_bg }}; --gc-buy-bg-hover: {{ plp_buy_bg_hover }}; --gc-buy-text: {{ plp_buy_text }}; --gc-buy-text-size: {{ plp_buy_text_size }}px; --gc-buy-radius: {{ plp_buy_radius }}px;">
  <div class="plp-mobile-overlay" data-mobile-filter-overlay></div>
  <div class="max-w-none mx-auto section-layout-px" style="max-width: {{ section_max_width }}px;">
    <div class="plp-layout">
      <aside class="plp-sidebar p-4 md:p-5 h-max md:sticky md:top-28" data-mobile-filter-drawer>
        <form method="get" action="{{ plp_base_url }}" data-plp-filter-form>
          {% if plp_is_search and plp_search_terms != blank %}
            <input type="hidden" name="q" value="{{ plp_search_terms | escape }}">
          {% endif %}
          {% assign active_filters_count = 0 %}
          {% assign has_active_filters = false %}
          {% for filter in plp_filters %}
            {% if filter.type == 'list' %}
              {% assign active_filters_count = active_filters_count | plus: filter.active_values.size %}
              {% if filter.active_values.size > 0 %}
                {% assign has_active_filters = true %}
              {% endif %}
            {% elsif filter.type == 'price_range' %}
              {% if filter.min_value.value %}
                {% assign active_filters_count = active_filters_count | plus: 1 %}
                {% assign has_active_filters = true %}
              {% endif %}
              {% if filter.max_value.value %}
                {% assign active_filters_count = active_filters_count | plus: 1 %}
                {% assign has_active_filters = true %}
              {% endif %}
            {% elsif filter.type == 'boolean' %}
              {% if filter.true_value.active %}
                {% assign active_filters_count = active_filters_count | plus: 1 %}
                {% assign has_active_filters = true %}
              {% endif %}
            {% endif %}
          {% endfor %}

          <div class="plp-sidebar-header">
            <p class="plp-filter-label plp-filter-title font-headline font-black">{{ plp_filter_title_main }}</p>
            <div class="flex items-center gap-2">
              {% if active_filters_count > 0 %}
                <span class="plp-filter-badge">{{ active_filters_count }}</span>
              {% endif %}
              <button class="plp-sidebar-toggle-close md:hidden" type="button" data-mobile-filter-close aria-label="Fechar filtros">
                <span class="material-symbols-outlined text-base">close</span>
              </button>
              <a href="{{ plp_base_url }}{% if plp_is_search and plp_search_terms != blank %}?q={{ plp_search_terms | url_encode }}{% endif %}{% if current_sort != blank %}{% if plp_is_search and plp_search_terms != blank %}&{% else %}?{% endif %}sort_by={{ current_sort | url_encode }}{% endif %}" class="plp-clear-filters">Limpar</a>
            </div>
          </div>

          <div class="plp-filter-group pt-4 first:pt-0">
            <h3 class="plp-filter-label plp-filter-title font-headline font-bold mb-3">{{ plp_filter_title_sort }}</h3>
            <div class="plp-sort-field">
              <span class="material-symbols-outlined plp-sort-field-icon" aria-hidden="true">swap_vert</span>
              <select class="plp-sort-select" name="sort_by" data-auto-submit aria-label="Ordenar produtos">
                {% if plp_is_search %}
                  <option value="relevance" {% if current_sort == 'relevance' or current_sort == blank %}selected{% endif %}>Relevancia</option>
                  <option value="price-ascending" {% if current_sort == 'price-ascending' %}selected{% endif %}>Menor preco</option>
                  <option value="price-descending" {% if current_sort == 'price-descending' %}selected{% endif %}>Maior preço</option>
                  <option value="date-descending" {% if current_sort == 'date-descending' %}selected{% endif %}>Mais recentes</option>
                {% else %}
                  <option value="manual" {% if current_sort == 'manual' or current_sort == blank %}selected{% endif %}>Relevancia</option>
                  <option value="price-ascending" {% if current_sort == 'price-ascending' %}selected{% endif %}>Menor preco</option>
                  <option value="title-ascending" {% if current_sort == 'title-ascending' %}selected{% endif %}>Nome A-Z</option>
                  <option value="best-selling" {% if current_sort == 'best-selling' %}selected{% endif %}>Mais vendidos</option>
                {% endif %}
              </select>
            </div>
          </div>

          {% if has_active_filters %}
            <div class="plp-active-filters" aria-label="Filtros ativos">
              {% for filter in plp_filters %}
                {% if filter.type == 'list' %}
                  {% for value in filter.active_values %}
                    <span class="plp-active-chip">{{ value.label }}</span>
                  {% endfor %}
                {% elsif filter.type == 'price_range' %}
                  {% if filter.min_value.value %}
                    <span class="plp-active-chip">Min {{ filter.min_value.value | money }}</span>
                  {% endif %}
                  {% if filter.max_value.value %}
                    <span class="plp-active-chip">Max {{ filter.max_value.value | money }}</span>
                  {% endif %}
                {% elsif filter.type == 'boolean' and filter.true_value.active %}
                  <span class="plp-active-chip">{{ filter.true_value.label }}</span>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          {% for filter in plp_filters %}
            <div class="plp-filter-group pt-4 first:pt-0">
              <h3 class="plp-filter-label plp-filter-title font-headline font-bold mb-3">{{ filter.label }}</h3>

              {% assign filter_label_downcase = filter.label | downcase %}
              {% if filter.type == 'list' and filter_label_downcase contains 'cor' %}
                <div class="plp-color-grid">
                  {% for value in filter.values %}
                    {% liquid
                      assign plp_display_count = value.count
                      if product_min_inventory > 0
                        assign plp_custom_count = 0
                        if filter.param_name contains 'product_type'
                          assign plp_acc_items = plp_valid_types_acc | split: '||'
                          for plp_acc_item in plp_acc_items
                            if plp_acc_item == value.value
                              assign plp_custom_count = plp_custom_count | plus: 1
                            endif
                          endfor
                          assign plp_display_count = plp_custom_count
                        elsif filter.param_name contains 'vendor'
                          assign plp_acc_items = plp_valid_vendors_acc | split: '||'
                          for plp_acc_item in plp_acc_items
                            if plp_acc_item == value.value
                              assign plp_custom_count = plp_custom_count | plus: 1
                            endif
                          endfor
                          assign plp_display_count = plp_custom_count
                        elsif filter.param_name contains '.tag'
                          assign plp_acc_items = plp_valid_tags_acc | split: '||'
                          for plp_acc_item in plp_acc_items
                            if plp_acc_item == value.value
                              assign plp_custom_count = plp_custom_count | plus: 1
                            endif
                          endfor
                          assign plp_display_count = plp_custom_count
                        endif
                      endif
                    %}
                    {% if plp_display_count > 0 or value.active %}
                      {% assign color_label = value.label | downcase %}
                      <label class="plp-color-option">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value | escape }}" {% if value.active %}checked{% endif %} data-auto-submit>
                        <span class="text-xs plp-filter-help">{{ value.label }}{% if plp_display_count > 0 %} ({{ plp_display_count }}){% endif %}</span>
                      </label>
                    {% endif %}
                  {% endfor %}
                </div>
              {% elsif filter.type == 'list' %}
                <div class="plp-list-filter-grid">
                  {% for value in filter.values %}
                    {% liquid
                      assign plp_display_count = value.count
                      if product_min_inventory > 0
                        assign plp_custom_count = 0
                        if filter.param_name contains 'product_type'
                          assign plp_acc_items = plp_valid_types_acc | split: '||'
                          for plp_acc_item in plp_acc_items
                            if plp_acc_item == value.value
                              assign plp_custom_count = plp_custom_count | plus: 1
                            endif
                          endfor
                          assign plp_display_count = plp_custom_count
                        elsif filter.param_name contains 'vendor'
                          assign plp_acc_items = plp_valid_vendors_acc | split: '||'
                          for plp_acc_item in plp_acc_items
                            if plp_acc_item == value.value
                              assign plp_custom_count = plp_custom_count | plus: 1
                            endif
                          endfor
                          assign plp_display_count = plp_custom_count
                        elsif filter.param_name contains '.tag'
                          assign plp_acc_items = plp_valid_tags_acc | split: '||'
                          for plp_acc_item in plp_acc_items
                            if plp_acc_item == value.value
                              assign plp_custom_count = plp_custom_count | plus: 1
                            endif
                          endfor
                          assign plp_display_count = plp_custom_count
                        endif
                      endif
                    %}
                    {% if plp_display_count > 0 or value.active %}
                      <label class="flex items-center gap-3 text-sm plp-filter-help">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value | escape }}" {% if value.active %}checked{% endif %} data-auto-submit>
                        <span>{{ value.label }} ({{ plp_display_count }})</span>
                      </label>
                    {% endif %}
                  {% endfor %}
                </div>
              {% elsif filter.type == 'price_range' %}
                <div class="grid grid-cols-2 gap-2">
                  <input class="plp-price-input" name="{{ filter.min_value.param_name }}" type="number" min="0" placeholder="Min" {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %} data-auto-submit-number>
                  <input class="plp-price-input" name="{{ filter.max_value.param_name }}" type="number" min="0" placeholder="Max" {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %} data-auto-submit-number>
                </div>
                <div class="plp-price-presets">
                  <button class="plp-price-preset" type="button" data-price-max="500">Até R$ 500</button>
                  <button class="plp-price-preset" type="button" data-price-max="1000">Até R$ 1.000</button>
                  <button class="plp-price-preset" type="button" data-price-max="2000">Até R$ 2.000</button>
                  <button class="plp-price-preset" type="button" data-price-max="3000">Até R$ 3.000</button>
                </div>
                <p class="plp-filter-help text-xs mt-2">Até {{ filter.range_max | money }}</p>
              {% elsif filter.type == 'boolean' %}
                <label class="flex items-center gap-3 text-sm plp-filter-help">
                  <input type="checkbox" name="{{ filter.param_name }}" value="1" {% if filter.true_value.active %}checked{% endif %} data-auto-submit>
                  <span>{{ filter.true_value.label }}</span>
                </label>
              {% endif %}
            </div>
          {% endfor %}

          {% unless has_native_color_filter %}
            {% assign fallback_colors_array = fallback_color_values | split: '||' %}
            {% assign fallback_colors_count = 0 %}
            {% for fallback_color in fallback_colors_array %}
              {% if fallback_color != blank %}
                {% assign fallback_colors_count = fallback_colors_count | plus: 1 %}
              {% endif %}
            {% endfor %}

            {% if fallback_colors_count > 0 %}
              <div class="plp-filter-group pt-4">
                <h3 class="plp-filter-label plp-filter-title font-headline font-bold mb-3">{{ plp_filter_title_color_label }}</h3>
                <div class="plp-color-grid">
                  {% for fallback_color in fallback_colors_array %}
                    {% if fallback_color != blank %}
                      {% assign fallback_color_normalized = fallback_color | downcase | strip %}
                      <label class="plp-color-option">
                        <input type="checkbox" data-client-color value="{{ fallback_color_normalized | escape }}">
