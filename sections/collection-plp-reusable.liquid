                {% if collection_current_page < collection_total_pages_filtered %}
                  {% assign collection_next_page = collection_current_page | plus: 1 %}
                  <button class="plp-pagination-link" type="button" aria-label="Proxima pagina" onclick="plpGoTo(this)" data-page-url="{{ plp_base_url }}{{ collection_query_base }}{% if collection_query_base == blank %}?{% else %}&{% endif %}page={{ collection_next_page }}">
                    <span class="material-symbols-outlined">chevron_right</span>
                  </button>
                {% endif %}
              </nav>
            {% endif %}
          </div>
        {% endif %}
      </section>

          {% liquid
            assign collection_total_pages_filtered = plp_collection_filtered_total | divided_by: products_per_page
            assign collection_total_remainder_filtered = plp_collection_filtered_total | modulo: products_per_page
            if collection_total_remainder_filtered > 0
              assign collection_total_pages_filtered = collection_total_pages_filtered | plus: 1
            endif
          %}

          {% if collection_current_page > collection_total_pages_filtered and collection_total_pages_filtered > 0 %}
            <script>
              (function() {
                const url = new URL(window.location.href);
                if ({{ collection_total_pages_filtered }} > 1) {
                  url.searchParams.set('page', '{{ collection_total_pages_filtered }}');
                } else {
                  url.searchParams.delete('page');
                }
                window.location.replace(url.toString());
              })();
            </script>
          {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .plp-ajax-loading-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: none;
    flex-direction: column;
    gap: 16px;
    background: color-mix(in srgb, {{ section_bg }} 85%, transparent);
    backdrop-filter: blur(2px);
    border-radius: 12px;
    padding: 0;
    pointer-events: all;
    align-items: stretch;
    min-height: 200px;
  }

  #shopify-section-{{ section.id }} .plp-ajax-loading-overlay.is-visible {
    display: flex;
  }

  #shopify-section-{{ section.id }} .plp-skeleton-grid {
    display: flex;
    flex-wrap: wrap;
    gap: {{ plp_gap_mobile }}px;
    padding: 0;
    width: 100%;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .plp-skeleton-grid {
      gap: {{ plp_gap_desktop }}px;
    }
  }

  #shopify-section-{{ section.id }} .plp-skeleton-card {
    flex: 0 0 auto;
    width: min(100%, clamp({{ card_width_mobile_min }}px, calc((100% - {{ plp_gap_mobile }}px) / 2), {{ card_width_mobile_max }}px));
    min-height: clamp({{ card_height_mobile_min }}px, 58vw, {{ card_height_mobile_max }}px);
    border-radius: {{ plp_card_radius }}px;
    background: linear-gradient(90deg, color-mix(in srgb, {{ section_text }} 8%, transparent) 25%, color-mix(in srgb, {{ section_text }} 14%, transparent) 50%, color-mix(in srgb, {{ section_text }} 8%, transparent) 75%);
    background-size: 200% 100%;
    animation: plp-shimmer 1.4s infinite linear;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .plp-skeleton-card {
      width: calc((100% - ({{ cards_per_row | minus: 1 }} * {{ plp_gap_desktop }}px)) / {{ cards_per_row }});
      min-height: var(--gc-card-height-desktop);
      max-height: var(--gc-card-height-desktop);
    }
  }

  @keyframes plp-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>

<script>
  window.PLPConfig = {
    sectionId:    '{{ section.id }}',
    skeletonCount: {{ section.settings.products_per_page | default: 12 }},
    isSearchPage:  {{ plp_is_search | json }},
    searchTerm:    {{ plp_search_terms | json }}
  };
</script>
<script src="{{ 'plp.js' | asset_url }}" defer></script>



