{% liquid
  assign section_bg = settings.global_surface_base_color | default: '#F7F7F7'
  assign section_text = settings.global_text_primary_color | default: '#1a1c1c'
  assign section_muted = settings.global_text_muted_color | default: '#6B7280'
  assign plp_filter_panel_bg = section.settings.filter_panel_bg | default: '#ffffff'
  assign plp_filter_panel_text = section.settings.filter_panel_text_color | default: section_text
  assign plp_filter_title_color = section.settings.filter_title_color | default: plp_filter_panel_text
  assign plp_filter_title_size_mobile = section.settings.filter_title_size_mobile | default: 16
  assign plp_filter_title_size_desktop = section.settings.filter_title_size_desktop | default: 18
  assign plp_filter_title_main = section.settings.filter_title_main | default: 'Filtros'
  assign plp_filter_title_sort = section.settings.filter_title_sort | default: 'Ordenacao'
  assign plp_filter_title_color_label = section.settings.filter_title_color_label | default: 'Cor'
  assign plp_filter_title_price = section.settings.filter_title_price | default: 'Preço'
  assign plp_filter_title_other = section.settings.filter_title_other | default: 'Outros'
  assign plp_filter_panel_border = section.settings.filter_panel_border_color | default: settings.global_border_color | default: '#E5E7EB'
  assign plp_filter_help_color = section.settings.filter_help_color | default: section_muted
  assign global_installments_count = settings.global_installments_count | default: 10 | plus: 0
  assign product_min_inventory = settings.global_product_card_min_inventory | default: 0 | plus: 0
  assign plp_filter_input_bg = section.settings.filter_input_bg | default: '#ffffff'
  assign plp_filter_input_text = section.settings.filter_input_text_color | default: section_text
  assign plp_filter_input_border = section.settings.filter_input_border_color | default: plp_filter_panel_border
  assign plp_filter_chip_bg = section.settings.filter_chip_bg | default: '#ffffff'
  assign plp_filter_chip_text = section.settings.filter_chip_text_color | default: section_text
  assign plp_filter_chip_border = section.settings.filter_chip_border_color | default: plp_filter_input_border
  assign plp_mobile_toolbar_bg = section.settings.mobile_filter_toolbar_bg | default: section_bg
  assign plp_mobile_toolbar_border = section.settings.mobile_filter_toolbar_border | default: plp_filter_panel_border
  assign plp_mobile_filter_btn_bg = section.settings.mobile_filter_button_bg | default: settings.global_primary_color | default: '#0058BB'
  assign plp_mobile_filter_btn_text = section.settings.mobile_filter_button_text_color | default: settings.global_button_primary_text_color | default: '#ffffff'
  assign plp_mobile_filter_btn_border = section.settings.mobile_filter_button_border_color | default: plp_mobile_filter_btn_bg
  assign plp_mobile_filter_btn_icon = section.settings.mobile_filter_button_icon_color | default: plp_mobile_filter_btn_text
  assign plp_mobile_overlay_bg = section.settings.mobile_filter_overlay_color | default: '#1a1c1c59'
  assign plp_filter_badge_bg = section.settings.filter_badge_bg | default: settings.global_primary_color | default: '#0058BB'
  assign plp_filter_badge_text = section.settings.filter_badge_text_color | default: settings.global_button_primary_text_color | default: '#ffffff'
  assign products_per_page = section.settings.products_per_page | default: 12
  assign cards_per_row = section.settings.cards_per_row | default: 4
  assign collection_title_size_mobile = section.settings.collection_title_size_mobile | default: 30
  assign collection_title_size_desktop = section.settings.collection_title_size_desktop | default: 44
  assign card_width_mobile_min = 150
  assign card_width_mobile_max = 230
  assign card_height_mobile_min = 320
  assign card_height_mobile_max = 430
  assign plp_is_search = false
  assign plp_base_url = collection.url
  assign plp_title = collection.title
  assign plp_description = collection.description | strip_html | downcase
  assign plp_results_count = collection.products_count
  assign plp_collection_filtered_total = 0
  assign plp_filters = collection.filters
  assign plp_search_terms = search.terms | default: ''
  assign plp_search_products = blank
  assign plp_valid_types_acc = ''
  assign plp_valid_vendors_acc = ''
  assign plp_valid_tags_acc = ''
  assign current_sort = collection.sort_by | default: 'manual'

  if request.page_type == 'search'
    assign plp_is_search = true
    assign plp_base_url = routes.search_url
    assign plp_title = section.settings.search_title | default: 'Resultados da busca'
    assign plp_description = blank
    assign plp_search_products = search.results | where: 'object_type', 'product'
    assign plp_results_count = 0
    assign plp_filters = search.filters
    assign current_sort = search.sort_by | default: 'relevance'
  endif

  if global_installments_count < 1
    assign global_installments_count = 1
  endif

  if product_min_inventory < 0
    assign product_min_inventory = 0
  endif

  if plp_is_search
    assign plp_results_count = 0
    for search_product in plp_search_products
      assign meets_min_inventory = true
      assign search_product_variant = search_product.selected_or_first_available_variant

      if search_product_variant.inventory_management == 'shopify'
        assign search_inventory_quantity = search_product_variant.inventory_quantity | default: 0 | plus: 0
        if search_inventory_quantity < product_min_inventory
          assign meets_min_inventory = false
        endif
      elsif search_product.available == false
        assign meets_min_inventory = false
      endif

      if meets_min_inventory
        assign plp_results_count = plp_results_count | plus: 1
        if search_product.type != blank
          assign plp_valid_types_acc = plp_valid_types_acc | append: '||' | append: search_product.type
        endif
        if search_product.vendor != blank
          assign plp_valid_vendors_acc = plp_valid_vendors_acc | append: '||' | append: search_product.vendor
        endif
        for plp_tag_item in search_product.tags
          assign plp_valid_tags_acc = plp_valid_tags_acc | append: '||' | append: plp_tag_item
        endfor
      endif
    endfor
  else
    assign plp_collection_filtered_total = 0
    for collection_product in collection.products
      assign meets_min_inventory = true
      assign collection_product_variant = collection_product.selected_or_first_available_variant

      if collection_product_variant.inventory_management == 'shopify'
        assign collection_inventory_quantity = collection_product_variant.inventory_quantity | default: 0 | plus: 0
        if collection_inventory_quantity < product_min_inventory
          assign meets_min_inventory = false
        endif
      elsif collection_product.available == false
        assign meets_min_inventory = false
      endif

      if meets_min_inventory
        assign plp_collection_filtered_total = plp_collection_filtered_total | plus: 1
        if collection_product.type != blank
          assign plp_valid_types_acc = plp_valid_types_acc | append: '||' | append: collection_product.type
        endif
        if collection_product.vendor != blank
          assign plp_valid_vendors_acc = plp_valid_vendors_acc | append: '||' | append: collection_product.vendor
        endif
        for plp_tag_item in collection_product.tags
          assign plp_valid_tags_acc = plp_valid_tags_acc | append: '||' | append: plp_tag_item
        endfor
      endif
    endfor
    assign plp_results_count = plp_collection_filtered_total
  endif

  assign card_width_mobile_min_raw = section.settings.card_width_mobile_min | strip
  assign card_width_mobile_max_raw = section.settings.card_width_mobile_max | strip
  assign card_height_mobile_min_raw = section.settings.card_height_mobile_min | strip
  assign card_height_mobile_max_raw = section.settings.card_height_mobile_max | strip
  assign priority_card_width_mobile_raw = section.settings.priority_card_width_mobile | strip
  assign priority_card_height_mobile_raw = section.settings.priority_card_height_mobile | strip
  assign priority_media_height_mobile_raw = section.settings.priority_media_height_mobile | strip

  if card_width_mobile_min_raw != blank
    assign parsed_width_min = card_width_mobile_min_raw | plus: 0
    if parsed_width_min > 0
      assign card_width_mobile_min = parsed_width_min
    endif
  endif

  if card_width_mobile_max_raw != blank
    assign parsed_width_max = card_width_mobile_max_raw | plus: 0
    if parsed_width_max > 0
      assign card_width_mobile_max = parsed_width_max
    endif
  endif

  if card_height_mobile_min_raw != blank
    assign parsed_height_min = card_height_mobile_min_raw | plus: 0
    if parsed_height_min > 0
      assign card_height_mobile_min = parsed_height_min
    endif
  endif

  if card_height_mobile_max_raw != blank
    assign parsed_height_max = card_height_mobile_max_raw | plus: 0
    if parsed_height_max > 0
      assign card_height_mobile_max = parsed_height_max
    endif
  endif

  assign plp_card_bg = settings.global_product_card_bg_color | default: settings.global_surface_card_color
  assign plp_card_border = settings.global_product_card_border_color | default: settings.global_border_color
  assign plp_card_border_hover = settings.global_product_card_border_hover_color | default: settings.global_primary_color
  assign plp_card_border_width = settings.global_product_card_border_width | default: 1
  assign plp_card_radius = settings.global_product_card_radius | default: 16
  assign plp_card_padding = settings.global_product_card_padding | default: 16
  assign plp_card_width_mobile = settings.global_product_card_width_mobile | default: 230
  assign plp_card_width_desktop = settings.global_product_card_width_desktop | default: 270
  assign plp_card_height_mobile = settings.global_product_card_height_mobile | default: 430
  assign plp_card_height_desktop = settings.global_product_card_height_desktop | default: 500
  assign plp_media_height_mobile = settings.global_product_card_media_height_mobile | default: 230
  assign plp_media_height_desktop = settings.global_product_card_media_height_desktop | default: 270

  if priority_card_width_mobile_raw != blank
    assign priority_card_width_mobile = priority_card_width_mobile_raw | plus: 0
    if priority_card_width_mobile > 0
      assign card_width_mobile_min = priority_card_width_mobile
      assign card_width_mobile_max = priority_card_width_mobile
      assign plp_card_width_mobile = priority_card_width_mobile
    endif
  endif

  if priority_card_height_mobile_raw != blank
    assign priority_card_height_mobile = priority_card_height_mobile_raw | plus: 0
    if priority_card_height_mobile > 0
      assign card_height_mobile_min = priority_card_height_mobile
      assign card_height_mobile_max = priority_card_height_mobile
      assign plp_card_height_mobile = priority_card_height_mobile
    endif
  endif

  if priority_media_height_mobile_raw != blank
    assign priority_media_height_mobile = priority_media_height_mobile_raw | plus: 0
    if priority_media_height_mobile > 0
      assign plp_media_height_mobile = priority_media_height_mobile
    endif
  endif

  if card_width_mobile_min > card_width_mobile_max
    assign card_width_mobile_min = card_width_mobile_max
  endif

  if card_height_mobile_min > card_height_mobile_max
    assign card_height_mobile_min = card_height_mobile_max
  endif
  assign plp_title_color = settings.global_product_card_title_color | default: settings.global_text_primary_color
  assign plp_title_hover = settings.global_product_card_title_hover_color | default: settings.global_primary_color
  assign plp_meta_color = settings.global_product_card_meta_color | default: settings.global_text_muted_color
  assign plp_price_color = settings.global_product_card_price_color | default: settings.global_text_primary_color
  assign plp_discount_bg = settings.global_product_card_discount_badge_bg | default: settings.global_primary_color
  assign plp_discount_text = settings.global_product_card_discount_badge_text | default: settings.global_button_primary_text_color
  assign plp_buy_bg = settings.global_button_primary_bg_color | default: settings.global_primary_color
  assign plp_buy_bg_hover = settings.global_button_primary_bg_hover_color | default: '#004A9D'
  assign plp_buy_text = settings.global_button_primary_text_color
  assign plp_buy_radius = settings.global_button_primary_radius | default: 12
  assign plp_buy_text_size = settings.global_button_primary_text_size | default: 14
  assign plp_title_size_mobile = settings.global_product_title_size_mobile | default: 14
  assign plp_title_size_desktop = settings.global_product_title_size_desktop | default: 16
  assign plp_price_size_mobile = settings.global_product_price_size_mobile | default: 24
  assign plp_price_size_desktop = settings.global_product_price_size_desktop | default: 28
  assign plp_meta_size_mobile = settings.global_product_card_meta_size_mobile | default: 12
  assign plp_meta_size_desktop = settings.global_product_card_meta_size_desktop | default: 12
  assign plp_show_ratings = settings.global_product_card_show_ratings
  assign plp_show_buy_button = settings.global_product_card_show_buy_button
  assign plp_show_discount_badge = settings.global_product_card_show_discount_badge
  assign plp_buy_label = settings.global_product_card_buy_label | default: 'COMPRAR'
  assign plp_media_bg = settings.global_recommended_media_bg_color | default: settings.global_product_card_media_bg_color | default: '#F7F7F7'
  assign plp_image_fit = settings.global_product_card_image_fit | default: 'cover'
  assign plp_image_position = settings.global_product_card_image_position | default: 'center center'
  assign plp_rating_color = settings.global_recommended_rating_color | default: settings.global_product_card_rating_color | default: '#facc15'

  assign plp_sidebar_width = 290
  assign plp_layout_gap = 32
  assign plp_gap_mobile = 4
  assign plp_gap_desktop = 20
  assign cards_total_width = plp_card_width_desktop | times: cards_per_row
  assign cards_gaps_count = cards_per_row | minus: 1
  assign cards_total_gap_width = plp_gap_desktop | times: cards_gaps_count
  assign products_column_width = cards_total_width | plus: cards_total_gap_width
  assign section_width_cap = section.settings.section_max_width_cap | default: settings.global_layout_max_width | default: 1310
  assign section_max_width = section_width_cap

  assign has_native_color_filter = false
  assign has_native_price_filter = false
  assign fallback_color_tokens = '|'
  assign fallback_color_values = ''

  for filter in plp_filters
    assign filter_label_downcase = filter.label | downcase
    if filter.type == 'list'
      if filter_label_downcase contains 'cor' or filter_label_downcase contains 'color'
        assign has_native_color_filter = true
      endif
    endif
    if filter.type == 'price_range'
      assign has_native_price_filter = true
    endif
  endfor

  if plp_is_search
    for fallback_product in plp_search_products
      assign fp_meets_min = false
      for fp_variant in fallback_product.variants
        if fp_meets_min == false
          if fp_variant.inventory_management == 'shopify'
            assign fp_inv_qty = fp_variant.inventory_quantity | default: 0 | plus: 0
            if fp_inv_qty >= product_min_inventory
              assign fp_meets_min = true
            endif
          elsif fp_variant.available
            assign fp_meets_min = true
          endif
        endif
      endfor
      unless fp_meets_min
        continue
      endunless
      for option in fallback_product.options_with_values
        assign option_name_downcase = option.name | downcase
        if option_name_downcase contains 'cor' or option_name_downcase contains 'color'
          for option_value in option.values
            assign normalized_color = option_value | strip | downcase
            assign color_token = '|' | append: normalized_color | append: '|'
            unless fallback_color_tokens contains color_token
              assign fallback_color_tokens = fallback_color_tokens | append: normalized_color | append: '|'
              assign fallback_color_values = fallback_color_values | append: option_value | append: '||'
            endunless
          endfor
        endif
      endfor
    endfor
  else
    for fallback_product in collection.products
      assign fp_meets_min = false
      for fp_variant in fallback_product.variants
        if fp_meets_min == false
          if fp_variant.inventory_management == 'shopify'
            assign fp_inv_qty = fp_variant.inventory_quantity | default: 0 | plus: 0
            if fp_inv_qty >= product_min_inventory
              assign fp_meets_min = true
            endif
          elsif fp_variant.available
            assign fp_meets_min = true
          endif
        endif
      endfor
      unless fp_meets_min
        continue
      endunless
      for option in fallback_product.options_with_values
        assign option_name_downcase = option.name | downcase
        if option_name_downcase contains 'cor' or option_name_downcase contains 'color'
          for option_value in option.values
            assign normalized_color = option_value | strip | downcase
            assign color_token = '|' | append: normalized_color | append: '|'
            unless fallback_color_tokens contains color_token
              assign fallback_color_tokens = fallback_color_tokens | append: normalized_color | append: '|'
              assign fallback_color_values = fallback_color_values | append: option_value | append: '||'
            endunless
          endfor
        endif
      endfor
    endfor
  endif
%}

<style>
  #shopify-section-{{ section.id }} .plp-shell {
    background-color: {{ section_bg }};
    color: {{ section_text }};
  }

  #shopify-section-{{ section.id }} .plp-title {
    font-size: {{ collection_title_size_mobile }}px;
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .plp-subtitle {
    color: color-mix(in srgb, {{ section_text }} 70%, transparent);
  }

  #shopify-section-{{ section.id }} .plp-layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  #shopify-section-{{ section.id }} .plp-mobile-toolbar {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    gap: 0.6rem;
    align-items: center;
    overflow-x: auto;
    padding: 0.75rem 0 0.8rem;
    margin-bottom: 0.4rem;
    background: color-mix(in srgb, {{ plp_mobile_toolbar_bg }} 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid color-mix(in srgb, {{ plp_mobile_toolbar_border }} 60%, transparent);
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .plp-mobile-toolbar::-webkit-scrollbar { display: none; }

  #shopify-section-{{ section.id }} .plp-mobile-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid color-mix(in srgb, {{ plp_filter_input_border }} 65%, transparent);
    border-radius: 999px;
    background: {{ plp_filter_input_bg }};
    color: {{ plp_filter_input_text }};
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1;
    padding: 0.55rem 0.85rem;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .plp-mobile-filter-btn {
    border-color: color-mix(in srgb, {{ plp_mobile_filter_btn_border }} 70%, transparent);
    background: {{ plp_mobile_filter_btn_bg }};
    color: {{ plp_mobile_filter_btn_text }};
    font-weight: 400;
    box-shadow: 0 8px 16px -10px rgba(0, 0, 0, 0.28);
  }

  #shopify-section-{{ section.id }} .plp-mobile-filter-btn .material-symbols-outlined {
    color: {{ plp_mobile_filter_btn_icon }};
  }

  #shopify-section-{{ section.id }} .plp-mobile-overlay {
    position: fixed;
    inset: 0;
    background: {{ plp_mobile_overlay_bg }};
    opacity: 0;
    visibility: hidden;
    transition: opacity 180ms ease;
    z-index: 9998;
  }

  #shopify-section-{{ section.id }} .plp-mobile-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  #shopify-section-{{ section.id }} .plp-products-column {
    width: 100%;
    min-width: 0;
    position: relative;
  }

  #shopify-section-{{ section.id }} .plp-sidebar {
    border: 1px solid color-mix(in srgb, {{ plp_filter_panel_border }} 70%, transparent);
    border-radius: 16px;
    background: {{ plp_filter_panel_bg }};
    color: {{ plp_filter_panel_text }};
  }

  #shopify-section-{{ section.id }} .plp-sidebar-toggle-close {
    border: 1px solid color-mix(in srgb, {{ plp_filter_input_border }} 70%, transparent);
    border-radius: 999px;
    width: 1.9rem;
    height: 1.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: {{ plp_filter_input_bg }};
    color: {{ plp_filter_input_text }};
  }

  #shopify-section-{{ section.id }} .plp-sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.9rem;
    margin-bottom: 0.65rem;
    border-bottom: 1px solid color-mix(in srgb, {{ plp_filter_panel_border }} 65%, transparent);
  }

  #shopify-section-{{ section.id }} .plp-clear-filters {
    border: 1px solid color-mix(in srgb, {{ plp_filter_input_border }} 70%, transparent);
    border-radius: 10px;
    background: {{ plp_filter_input_bg }};
    color: {{ plp_filter_input_text }};
    font-size: 0.8rem;
    font-weight: 400;
    padding: 0.45rem 0.75rem;
    line-height: 1;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .plp-filter-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.4rem;
    height: 1.4rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    background: {{ plp_filter_badge_bg }};
    color: {{ plp_filter_badge_text }};
    font-size: 0.7rem;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .plp-filter-group {
    padding-bottom: 0.7rem;
  }

  #shopify-section-{{ section.id }} .plp-filter-group + .plp-filter-group {
    border-top: 1px solid color-mix(in srgb, {{ plp_filter_panel_border }} 55%, transparent);
    margin-top: 0.35rem;
    padding-top: 0.95rem;
  }

  #shopify-section-{{ section.id }} .plp-filter-label {
    color: {{ plp_filter_panel_text }};
    margin-bottom: 0.55rem;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .plp-filter-title {
    color: {{ plp_filter_title_color }};
    font-size: {{ plp_filter_title_size_mobile }}px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .plp-filter-help {
    color: {{ plp_filter_help_color }};
  }

  #shopify-section-{{ section.id }} .plp-active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.25rem 0 0.5rem;
    max-height: 130px;
    overflow-y: auto;
    padding-right: 4px;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, {{ section_text }} 32%, transparent) transparent;
  }

  #shopify-section-{{ section.id }} .plp-active-filters::-webkit-scrollbar {
    width: 1px;
  }

  #shopify-section-{{ section.id }} .plp-active-filters::-webkit-scrollbar-track {
    background: transparent;
  }

  #shopify-section-{{ section.id }} .plp-active-filters::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, {{ section_text }} 32%, transparent);
  }

  #shopify-section-{{ section.id }} .plp-active-chip {
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, {{ plp_filter_chip_border }} 70%, transparent);
    background: {{ plp_filter_chip_bg }};
    color: {{ plp_filter_chip_text }};
    font-size: 0.72rem;
    font-weight: 400;
    padding: 0.3rem 0.6rem;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .plp-color-grid {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-height: 220px;
    overflow-y: auto;
    padding-right: 4px;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, {{ section_text }} 32%, transparent) transparent;
  }

  #shopify-section-{{ section.id }} .plp-color-grid::-webkit-scrollbar {
    width: 1px;
  }

  #shopify-section-{{ section.id }} .plp-color-grid::-webkit-scrollbar-track {
    background: transparent;
  }

