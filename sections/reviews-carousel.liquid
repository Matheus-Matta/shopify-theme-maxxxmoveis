{% liquid
  assign section_bg = section.settings.section_bg_color
  assign section_text = section.settings.section_text_color
  assign review_card_bg = section.settings.review_card_bg_color
  assign review_card_border = section.settings.review_card_border_color
  assign review_card_border_width = section.settings.review_card_border_width | default: 1
  assign review_card_text = section.settings.review_card_text_color
  assign review_card_muted = section.settings.review_card_muted_color
  assign reviews_arrow_bg = settings.global_arrow_bg_color | default: section.settings.arrow_bg_color | default: '#ffffff'
  assign reviews_arrow_border = settings.global_arrow_border_color | default: section.settings.arrow_border_color | default: '#D1D5DB'
  assign reviews_arrow_icon = settings.global_arrow_icon_color | default: section.settings.arrow_color | default: '#1a1c1c'
  assign reviews_arrow_bg_hover = settings.global_arrow_bg_hover_color | default: section.settings.arrow_bg_hover_color | default: '#F3F4F6'
  assign reviews_arrow_border_hover = settings.global_arrow_border_hover_color | default: section.settings.arrow_border_hover_color | default: '#0058BB'
  assign reviews_arrow_icon_hover = settings.global_arrow_icon_hover_color | default: section.settings.arrow_color_hover | default: '#0058BB'
%}

<section class="w-full section-layout-py overflow-hidden" style="--section-bg: {{ section_bg }}; --section-text: {{ section_text }}; --review-card-bg: {{ review_card_bg }}; --review-card-border: {{ review_card_border }}; --review-card-border-width: {{ review_card_border_width }}px; --review-card-text: {{ review_card_text }}; --review-card-muted: {{ review_card_muted }}; --review-card-height-mobile: {{ section.settings.card_height_mobile | default: 280 }}px; --review-card-height-desktop: {{ section.settings.card_height_desktop | default: 300 }}px; --gc-track-gap-mobile: 16px; --gc-track-gap-desktop: 24px; --gc-track-padding-mobile: 0.25rem 0.1rem 0.6rem 0.1rem; --gc-track-padding-desktop: 0.3rem 0.2rem 0.75rem 0.2rem; background-color: var(--section-bg);">
  <div class="max-w-[1440px] mx-auto section-layout-px">
    <div class="relative flex items-center mb-4 md:mb-6">
      <div class="flex-grow border-t" style="border-color: color-mix(in srgb, {{ section.settings.title_color }} 15%, transparent);"></div>
      <h2 class="reviews-carousel__title flex-shrink mx-4 font-headline uppercase tracking-tight" style="--title-size-mobile: {{ section.settings.title_size_mobile }}px; --title-size-desktop: {{ section.settings.title_size_desktop }}px; color: {{ section.settings.title_color }}; font-weight: bold;">{{ section.settings.title }}</h2>
      <div class="flex-grow border-t" style="border-color: color-mix(in srgb, {{ section.settings.title_color }} 15%, transparent);"></div>
    </div>

    <div class="relative group">
      <button id="prev-btn-{{ section.id }}" class="reviews-arrow absolute left-[-20px] md:left-[-20px] top-1/2 -translate-y-1/2 z-10 rounded-full shadow-md border hidden md:flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed" style="width: {{ section.settings.arrow_size }}px; height: {{ section.settings.arrow_size }}px; background-color: {{ reviews_arrow_bg }}; border-color: {{ reviews_arrow_border }}; color: {{ reviews_arrow_icon }};" type="button" aria-label="Anterior">
        <span class="material-symbols-outlined" style="font-size: {{ section.settings.arrow_icon_size }}px;">chevron_left</span>
      </button>
      <button id="next-btn-{{ section.id }}" class="reviews-arrow absolute right-[-20px] md:right-[-20px] top-1/2 -translate-y-1/2 z-10 rounded-full shadow-md border hidden md:flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed" style="width: {{ section.settings.arrow_size }}px; height: {{ section.settings.arrow_size }}px; background-color: {{ reviews_arrow_bg }}; border-color: {{ reviews_arrow_border }}; color: {{ reviews_arrow_icon }};" type="button" aria-label="Próximo">
        <span class="material-symbols-outlined" style="font-size: {{ section.settings.arrow_icon_size }}px;">chevron_right</span>
      </button>

      <div id="carousel-{{ section.id }}" class="flex gc-unified-track overflow-x-auto no-scrollbar snap-x scroll-smooth">
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }}>
            {% render 'review-card', 
              review_link: block.settings.review_link,
              name: block.settings.name, 
              name_color: block.settings.name_color,
              name_size_mobile: block.settings.name_size_mobile,
              name_size_desktop: block.settings.name_size_desktop,
              meta: block.settings.meta, 
              meta_color: block.settings.meta_color,
              meta_size_mobile: block.settings.meta_size_mobile,
              meta_size_desktop: block.settings.meta_size_desktop,
              text: block.settings.text, 
              text_color: block.settings.text_color,
              stars: block.settings.stars,
              star_color: block.settings.star_color,
              avatar: block.settings.avatar,
              avatar_bg: block.settings.avatar_bg
            %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .reviews-carousel__title {
    font-size: var(--title-size-mobile, 20px);
  }

  #shopify-section-{{ section.id }} .review-card {
    height: var(--review-card-height-mobile, 280px);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .review-card .review-card__text {
    max-height: calc(var(--review-card-height-mobile, 280px) - 140px);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .review-card .review-card__name {

  #shopify-section-{{ section.id }} .review-card .review-card__meta {
    font-size: var(--review-meta-size-mobile, 11px);
  }

  #shopify-section-{{ section.id }} .reviews-arrow {
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  #shopify-section-{{ section.id }} .reviews-arrow:hover {
    background-color: {{ reviews_arrow_bg_hover }} !important;
    border-color: {{ reviews_arrow_border_hover }} !important;
    color: {{ reviews_arrow_icon_hover }} !important;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .review-card {
      height: var(--review-card-height-desktop, 300px);
    }

    #shopify-section-{{ section.id }} .review-card .review-card__text {
      max-height: calc(var(--review-card-height-desktop, 300px) - 140px);
    }

    #shopify-section-{{ section.id }} .reviews-carousel__title {
      font-size: var(--title-size-desktop, 24px);
    }

    #shopify-section-{{ section.id }} .review-card .review-card__name {
      font-size: var(--review-name-size-desktop, 16px);
    }

    #shopify-section-{{ section.id }} .review-card .review-card__meta {
      font-size: var(--review-meta-size-desktop, 12px);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track   = document.getElementById('carousel-{{ section.id }}');
    const prevBtn = document.getElementById('prev-btn-{{ section.id }}');
    const nextBtn = document.getElementById('next-btn-{{ section.id }}');

    if (!track || !prevBtn || !nextBtn) return;

    const autoplayEnabled    = {{ section.settings.autoplay_enabled | json }};
    const autoplayIntervalMs = {{ section.settings.autoplay_interval | default: 4 | times: 1000 }};

    const carousel = new window.CarouselController(track, {
      prev:          prevBtn,
      next:          nextBtn,
      slideSelector: '.review-card'
    });
    carousel.bind();

    if (autoplayEnabled) {
      const autoplay = new window.CarouselAutoplay(track, {
        intervalMs: autoplayIntervalMs,
        getStep:    function () { return carousel.getStep(); }
      });
      autoplay.bind();
    }
  });
</script>

