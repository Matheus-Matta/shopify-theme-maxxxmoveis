{% liquid
  assign category_shape = section.settings.category_shape | default: 'circle'
  assign category_chip_radius = '9999px'
  assign section_bg = section.settings.section_bg_color | default: settings.global_surface_card_color
  assign section_text = section.settings.section_text_color | default: settings.global_text_primary_color
  assign section_border = section.settings.section_border_color | default: settings.global_border_color
  assign chip_bg = section.settings.category_bg_color | default: settings.global_surface_base_color
  assign title_color = section.settings.category_title_color | default: settings.global_text_primary_color
  assign category_arrow_bg_color = settings.global_arrow_bg_color | default: section.settings.arrow_bg_color | default: '#ffffff'
  assign category_arrow_border_color = settings.global_arrow_border_color | default: section.settings.arrow_border_color | default: '#D1D5DB'
  assign category_arrow_icon_color = settings.global_arrow_icon_color | default: section.settings.arrow_icon_color | default: '#1a1c1c'
  assign category_arrow_bg_hover_color = settings.global_arrow_bg_hover_color | default: section.settings.arrow_bg_hover_color | default: '#F3F4F6'
  assign category_arrow_border_hover_color = settings.global_arrow_border_hover_color | default: section.settings.arrow_border_hover_color | default: '#0058BB'
  assign category_arrow_icon_hover_color = settings.global_arrow_icon_hover_color | default: section.settings.arrow_icon_hover_color | default: '#0058BB'
  assign view_all_color = section.settings.view_all_text_color | default: settings.global_primary_color
  assign view_all_hover = section.settings.view_all_hover_color | default: '#004A9D'

  if category_shape == 'rounded_square'
    assign category_chip_radius = section.settings.corner_radius | append: 'px'
  endif
%}

<style>
  #shopify-section-{{ section.id }} .home-categories__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .home-categories__heading {
    flex: 1 1 auto;
    min-width: 0;
    font-size: clamp(1rem, 0.82rem + 0.9vw, 1.5rem);
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .home-categories__arrows {
    flex: 0 0 auto;
  }

  #shopify-section-{{ section.id }} .home-categories__arrow {
    width: 2rem;
    height: 2rem;
  }

  #shopify-section-{{ section.id }} .home-categories__arrow .material-symbols-outlined {
    font-size: 18px;
  }

  #shopify-section-{{ section.id }} .home-categories__item {
    width: {{ section.settings.item_width_mobile }}px;
    text-align: {{ section.settings.title_align }};
  }

  #shopify-section-{{ section.id }} .home-categories__media {
    width: {{ section.settings.item_width_mobile }}px;
    height: {{ section.settings.item_height_mobile }}px;
  }

  #shopify-section-{{ section.id }} .home-categories__media-image {
    width: 100%;
    height: 100%;
    transform: scale(1);
    transition: transform 0.35s ease;
  }

  #shopify-section-{{ section.id }} .home-categories__title {
    display: block;
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .home-categories__arrow {
    background-color: var(--category-arrow-bg-color);
    border-color: var(--category-arrow-border-color);
    color: var(--category-arrow-icon-color);
  }

  #shopify-section-{{ section.id }} .home-categories__arrow:hover {
    background-color: var(--category-arrow-bg-hover-color);
    border-color: var(--category-arrow-border-hover-color);
    color: var(--category-arrow-icon-hover-color);
  }

  #shopify-section-{{ section.id }} .home-categories__view-all {
    color: {{ view_all_color }};
    font-size: 14px;
    font-weight: 700;
    display: none;
    align-items: center;
    gap: 0.375rem;
    white-space: nowrap;
    transition: color 0.2s ease;
    text-decoration: none;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .home-categories__view-all {
      display: flex;
    }
  }
  #shopify-section-{{ section.id }} .home-categories__view-all:hover {
    color: {{ view_all_hover }};
  }

  #shopify-section-{{ section.id }} .home-categories__item:hover .home-categories__media {
    border-color: var(--category-hover-border-color);
  }

  #shopify-section-{{ section.id }} .home-categories__item:hover .home-categories__title {
    color: var(--category-hover-title-color);
  }

  #shopify-section-{{ section.id }} .home-categories__item:hover .home-categories__media-image {
    transform: scale({{ section.settings.image_hover_scale }});
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .home-categories__heading {
      font-size: clamp(1.25rem, 0.95rem + 1.2vw, 2rem);
    }

    #shopify-section-{{ section.id }} .home-categories__arrow {
      width: 2.5rem;
      height: 2.5rem;
    }

    #shopify-section-{{ section.id }} .home-categories__arrow .material-symbols-outlined {
      font-size: 20px;
    }

    #shopify-section-{{ section.id }} .home-categories__item {
      width: {{ section.settings.item_width_desktop }}px;
    }

    #shopify-section-{{ section.id }} .home-categories__media {
      width: {{ section.settings.item_width_desktop }}px;
      height: {{ section.settings.item_height_desktop }}px;
    }
  }
</style>

<section class="section-layout-py" style="background-color: {{ section_bg }}; --section-bg: {{ section_bg }}; --section-text: {{ section_text }}; --section-border: {{ section_border }}; --category-chip-bg: {{ chip_bg }}; --category-title-color: {{ title_color }}; --category-hover-border-color: {{ section.settings.category_hover_border_color }}; --category-hover-title-color: {{ section.settings.category_hover_title_color }}; --category-arrow-bg-color: {{ category_arrow_bg_color }}; --category-arrow-border-color: {{ category_arrow_border_color }}; --category-arrow-icon-color: {{ category_arrow_icon_color }}; --category-arrow-bg-hover-color: {{ category_arrow_bg_hover_color }}; --category-arrow-border-hover-color: {{ category_arrow_border_hover_color }}; --category-arrow-icon-hover-color: {{ category_arrow_icon_hover_color }};">
  <div class="max-w-[1440px] mx-auto section-layout-px">
  <div class="home-categories__header mb-4 md:mb-6">
    <h2 class="home-categories__heading font-headline font-extrabold" style="color: var(--section-text);">{{ section.settings.title }}</h2>
    {% if section.settings.view_all_url != blank and section.settings.view_all_label != blank %}
      <a class="home-categories__view-all group hidden md:flex" href="{{ section.settings.view_all_url }}">
        {{ section.settings.view_all_label }} <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform" style="font-size:18px;">trending_flat</span>
      </a>
    {% endif %}
    <div class="home-categories__arrows flex gap-2">
      <button class="home-categories__arrow rounded-full border flex items-center justify-center transition-all" type="button" aria-label="Anterior" data-categories-prev><span class="material-symbols-outlined">chevron_left</span></button>
      <button class="home-categories__arrow rounded-full border flex items-center justify-center transition-all" type="button" aria-label="Próximo" data-categories-next><span class="material-symbols-outlined">chevron_right</span></button>
    </div>
  </div>

  <div class="flex overflow-x-auto no-scrollbar pb-2" style="gap: {{ section.settings.item_gap }}px;" data-categories-track>
    {% for block in section.blocks %}
      {% liquid
        assign category_collection = block.settings.collection
        assign category_image = block.settings.image
        assign category_title = block.settings.title
        assign category_link = block.settings.link
        assign category_image_url = ''

        if category_image == blank and category_collection != blank
          assign category_image = category_collection.featured_image
        endif

        if category_image != blank
          assign category_image_url = category_image | image_url: width: 900
        endif

        if category_title == blank and category_collection != blank
          assign category_title = category_collection.title
        endif

        if category_link == blank and category_collection != blank
          assign category_link = category_collection.url
        endif
      %}
      <div {{ block.shopify_attributes }}>
        <a class="home-categories__item group shrink-0" href="{{ category_link | default: '#' }}">
          <div class="home-categories__media mb-4 border-2 border-transparent transition-all overflow-hidden" style="background-color: var(--category-chip-bg, var(--color-surface)); border-radius: {{ category_chip_radius }};">
            <div class="home-categories__media-image" style="border-radius: {{ category_chip_radius }}; background-image: url('{{ category_image_url }}'); background-size: {{ section.settings.image_fit }}; background-position: {{ section.settings.image_position }}; background-repeat: {{ section.settings.image_repeat }};"></div>
          </div>
          <span class="home-categories__title font-bold block w-full" style="color: var(--category-title-color, var(--color-text)); font-size: {{ section.settings.title_size }}px; text-align: {{ section.settings.title_align }}; height: {{ section.settings.title_box_height }}px; line-height: {{ section.settings.title_box_height }}px;">{{ category_title }}</span>
        </a>
      </div>
    {% endfor %}
  </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionElement = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionElement) return;

    const track      = sectionElement.querySelector('[data-categories-track]');
    const prevButton = sectionElement.querySelector('[data-categories-prev]');
    const nextButton = sectionElement.querySelector('[data-categories-next]');

    if (!track || !prevButton || !nextButton) return;

    const carousel = new window.CarouselController(track, {
      prev:          prevButton,
      next:          nextButton,
      slideSelector: '.home-categories__item'
    });
    carousel.bind();
  });
</script>

