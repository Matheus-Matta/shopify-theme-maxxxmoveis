    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#1a1c1c"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 14, "max": 48, "step": 1, "unit": "px",
      "label": "Tamanho do título (mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 14, "max": 64, "step": 1, "unit": "px",
      "label": "Tamanho do título (desktop)",
      "default": 26
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Cor do subtítulo",
      "default": "#6B7280"
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "min": 11, "max": 24, "step": 1, "unit": "px",
      "label": "Tamanho do subtítulo (mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "min": 11, "max": 28, "step": 1, "unit": "px",
      "label": "Tamanho do subtítulo (desktop)",
      "default": 16
    },
    {
      "type": "header",
      "content": "Seção"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Fundo da seção",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Texto geral",
      "default": "#1a1c1c"
    },
    {
      "type": "header",
      "content": "Cards de Loja"
    },
    {
      "type": "range",
      "id": "card_width_mobile",
      "min": 200, "max": 400, "step": 10, "unit": "px",
      "label": "Largura do card (mobile)",
      "default": 260
    },
    {
      "type": "range",
      "id": "card_width_desktop",
      "min": 220, "max": 480, "step": 10, "unit": "px",
      "label": "Largura do card (desktop)",
      "default": 300
    },
    {
      "type": "range",
      "id": "card_media_height",
