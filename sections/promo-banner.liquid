{% liquid
  assign section_bg = '#f5f5f5'
  assign section_text = '#18181b'
  assign tile_bg = '#ffffff'
  assign content_bg = '#f8f8f8'
  assign eyebrow_color = '#0058BB'
  assign title_color = '#18181b'
  assign button_dark_bg = '#18181b'
  assign button_dark_text = '#ffffff'
  assign button_accent_bg = '#0058BB'
  assign button_accent_text = '#ffffff'

  assign section_bg = section.settings.section_bg_color | default: section_bg
  assign section_text = section.settings.section_text_color | default: section_text
  assign tile_bg = section.settings.tile_bg_color | default: tile_bg
  assign content_bg = section.settings.content_bg_color | default: content_bg
  assign eyebrow_color = section.settings.eyebrow_color | default: eyebrow_color
  assign title_color = section.settings.title_color | default: title_color
  assign button_dark_bg = section.settings.button_dark_bg_color | default: button_dark_bg
  assign button_dark_text = section.settings.button_dark_text_color | default: button_dark_text
  assign button_accent_bg = section.settings.button_accent_bg_color | default: button_accent_bg
  assign button_accent_text = section.settings.button_accent_text_color | default: button_accent_text
  assign tile_border_color = section.settings.tile_border_color | default: '#d4d4d8'
  assign content_border_color = section.settings.content_border_color | default: '#d4d4d8'
  assign button_border_color = section.settings.button_border_color | default: 'transparent'
  assign section_border_color = section.settings.section_border_color | default: '#d4d4d8'

  assign tile_max_height_mobile_css = 'none'
  if section.settings.tile_max_height_mobile > 0
    assign tile_max_height_mobile_css = section.settings.tile_max_height_mobile | append: 'px'
  endif

  assign tile_max_height_desktop_css = 'none'
  if section.settings.tile_max_height_desktop > 0
    assign tile_max_height_desktop_css = section.settings.tile_max_height_desktop | append: 'px'
  endif

  assign media_max_height_mobile_css = 'none'
  if section.settings.media_max_height_mobile > 0
    assign media_max_height_mobile_css = section.settings.media_max_height_mobile | append: 'px'
  endif

  assign media_max_height_desktop_css = 'none'
  if section.settings.media_max_height_desktop > 0
    assign media_max_height_desktop_css = section.settings.media_max_height_desktop | append: 'px'
  endif
%}

<style>
  #shopify-section-{{ section.id }} .promo-banner__grid {
    gap: {{ section.settings.grid_gap_mobile }}px;
  }

  #shopify-section-{{ section.id }} .promo-banner-section {
    border-style: solid;
    border-color: var(--promo-section-border);
    border-width: {{ section.settings.section_border_width_mobile }}px;
    border-radius: {{ section.settings.section_border_radius_mobile }}px;
  }

  #shopify-section-{{ section.id }} .promo-banner__tile {
    --promo-tile-radius: {{ section.settings.tile_radius_mobile }}px;
    --promo-tile-border-width: {{ section.settings.tile_border_width_mobile }}px;
    --promo-tile-border-hover: var(--promo-tile-border);
    border-radius: {{ section.settings.tile_radius_mobile }}px !important;
    min-height: {{ section.settings.tile_min_height_mobile }}px !important;
    max-height: {{ tile_max_height_mobile_css }} !important;
    border-style: solid;
    border-width: {{ section.settings.tile_border_width_mobile }}px !important;
    border-color: var(--promo-tile-border) !important;
  }

  #shopify-section-{{ section.id }} .promo-banner__media {
    min-height: {{ section.settings.media_min_height_mobile }}px !important;
    max-height: {{ media_max_height_mobile_css }} !important;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .promo-banner__media-bg {
    min-height: inherit;
  }

  #shopify-section-{{ section.id }} .promo-banner__content {
    padding: {{ section.settings.content_padding_mobile }}px !important;
    border-style: solid;
    border-color: var(--promo-content-border) !important;
    border-width: {{ section.settings.content_border_width_mobile }}px !important;
  }

  #shopify-section-{{ section.id }} .promo-banner__eyebrow {
    font-size: {{ section.settings.eyebrow_size_mobile }}px !important;
  }

  #shopify-section-{{ section.id }} .promo-banner__title {
    font-size: {{ section.settings.title_size_mobile }}px !important;
  }

  #shopify-section-{{ section.id }} .promo-banner__button {
    font-size: {{ section.settings.button_text_size_mobile }}px !important;
    border-style: solid;
    border-width: {{ section.settings.button_border_width_mobile }}px !important;
    border-color: var(--promo-button-border) !important;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .promo-banner__grid {
      gap: {{ section.settings.grid_gap_desktop }}px;
    }

    #shopify-section-{{ section.id }} .promo-banner-section {
      border-width: {{ section.settings.section_border_width_desktop }}px;
      border-radius: {{ section.settings.section_border_radius_desktop }}px;
    }

    #shopify-section-{{ section.id }} .promo-banner__tile {
      --promo-tile-radius: {{ section.settings.tile_radius_desktop }}px;
      --promo-tile-border-width: {{ section.settings.tile_border_width_desktop }}px;
      border-radius: {{ section.settings.tile_radius_desktop }}px !important;
      min-height: {{ section.settings.tile_min_height_desktop }}px !important;
      max-height: {{ tile_max_height_desktop_css }} !important;
      border-width: {{ section.settings.tile_border_width_desktop }}px !important;
    }

    #shopify-section-{{ section.id }} .promo-banner__media {
      min-height: {{ section.settings.media_min_height_desktop }}px !important;
      max-height: {{ media_max_height_desktop_css }} !important;
    }

    #shopify-section-{{ section.id }} .promo-banner__content {
      padding: {{ section.settings.content_padding_desktop }}px !important;
      border-width: {{ section.settings.content_border_width_desktop }}px !important;
    }

    #shopify-section-{{ section.id }} .promo-banner__eyebrow {
      font-size: {{ section.settings.eyebrow_size_desktop }}px !important;
    }

    #shopify-section-{{ section.id }} .promo-banner__title {
      font-size: {{ section.settings.title_size_desktop }}px !important;
    }

    #shopify-section-{{ section.id }} .promo-banner__button {
      font-size: {{ section.settings.button_text_size_desktop }}px !important;
      border-width: {{ section.settings.button_border_width_desktop }}px !important;
    }
  }
</style>

<section class="promo-banner-section section-layout-py" style="--section-bg: {{ section_bg }}; --section-text: {{ section_text }}; --promo-text: {{ section_text }}; --promo-section-border: {{ section_border_color }}; --promo-tile-bg: {{ tile_bg }}; --promo-content-bg: {{ content_bg }}; --promo-eyebrow: {{ eyebrow_color }}; --promo-title: {{ title_color }}; --promo-tile-border: {{ tile_border_color }}; --promo-content-border: {{ content_border_color }}; --promo-button-border: {{ button_border_color }}; --promo-button-dark-bg: {{ button_dark_bg }}; --promo-button-dark-text: {{ button_dark_text }}; --promo-button-accent-bg: {{ button_accent_bg }}; --promo-button-accent-text: {{ button_accent_text }};">
  <div class="max-w-[1440px] mx-auto section-layout-px">
  <div class="promo-banner__grid grid grid-cols-1 md:grid-cols-2">
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>
        {% render 'promo-tile', block_id: block.id, eyebrow: block.settings.eyebrow, title: block.settings.title, button_label: block.settings.button_label, button_link: block.settings.button_link, button_style: block.settings.button_style, button_radius: block.settings.button_radius, image: block.settings.image, image_fit: block.settings.image_fit, image_position: block.settings.image_position, image_scale: block.settings.image_scale, image_border_width: block.settings.image_border_width, image_border_color: block.settings.image_border_color, image_radius: block.settings.image_radius %}
      </div>
    {% endfor %}
  </div>
  </div>
</section>

