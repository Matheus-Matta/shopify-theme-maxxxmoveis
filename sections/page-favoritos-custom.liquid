<style>
  #shopify-section-{{ section.id }} .favorites-shell {
    max-width: 1440px;
    margin: 0 auto;
    padding: 1.25rem 1rem 1.5rem;
  }

  #shopify-section-{{ section.id }} .favorites-header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  #shopify-section-{{ section.id }} .favorites-title {
    margin: 0;
    font-size: clamp(1.8rem, 1.8vw + 1.2rem, 2.25rem);
    line-height: 1.12;
    font-weight: 600;
    color: {{ settings.global_text_primary_color | default: '#111827' }};
  }

  #shopify-section-{{ section.id }} .favorites-subtitle {
    margin: 0;
    color: {{ settings.global_text_muted_color | default: '#64748b' }};
    font-size: 0.95rem;
  }

  #shopify-section-{{ section.id }} .favorites-layout {
    display: grid;
    gap: 1.5rem;
  }

  #shopify-section-{{ section.id }} .favorites-list {
    background: {{ settings.global_surface_card_color | default: '#ffffff' }};
    border: 1px solid {{ settings.global_border_color | default: '#e5e7eb' }};
    border-radius: 18px;
    box-shadow: 0 12px 32px rgba(26, 28, 28, 0.06);
    padding: 1.25rem;
  }

  #shopify-section-{{ section.id }} .favorites-grid {
    display: grid;
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .fav-item {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid {{ settings.global_border_color | default: '#e5e7eb' }};
    border-radius: 12px;
    background: {{ settings.global_surface_base_color | default: '#f8fafc' }};
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  #shopify-section-{{ section.id }} .fav-item:hover {
    border-color: {{ settings.global_primary_color | default: '#0058BB' }};
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
  }

  #shopify-section-{{ section.id }} .fav-thumb {
    display: block;
    border-radius: 10px;
    overflow: hidden;
    background: #f1f5f9;
  }

  #shopify-section-{{ section.id }} .fav-image {
    width: 96px;
    height: 96px;
  }

  #shopify-section-{{ section.id }} .fav-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .fav-body {
    display: grid;
    gap: 0.5rem;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .fav-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
    color: {{ settings.global_text_primary_color | default: '#111827' }};
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .fav-title-link {
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .fav-price {
    margin: 0;
    font-size: 1rem;
    color: {{ settings.global_text_primary_color | default: '#111827' }};
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .fav-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  #shopify-section-{{ section.id }} .fav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.62rem 0.92rem;
    border-radius: 10px;
    font-size: 0.86rem;
    line-height: 1;
    font-weight: 400;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.18s ease;
  }

  #shopify-section-{{ section.id }} .fav-btn-primary {
    background: {{ settings.global_primary_color | default: '#0058BB' }};
    color: #fff;
  }

  #shopify-section-{{ section.id }} .fav-btn-primary:hover {
    background: {{ settings.global_primary_hover_color | default: '#004A9D' }};
  }

  #shopify-section-{{ section.id }} .fav-btn-outline {
    border-color: {{ settings.global_border_color | default: '#cbd5e1' }};
    background: #fff;
    color: {{ settings.global_text_primary_color | default: '#111827' }};
  }

  #shopify-section-{{ section.id }} .fav-btn-outline:hover {
    border-color: {{ settings.global_primary_color | default: '#0058BB' }};
    color: {{ settings.global_primary_color | default: '#0058BB' }};
  }

  #shopify-section-{{ section.id }} .fav-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .fav-add-form {
    margin: 0;
    display: inline-flex;
  }

  #shopify-section-{{ section.id }} .fav-add-form .fav-btn {
    width: 100%;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .favorites-shell {
      padding: 1rem 0.85rem 1.25rem;
    }

    #shopify-section-{{ section.id }} .favorites-header {
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    #shopify-section-{{ section.id }} .favorites-title {
      font-size: clamp(1.45rem, 7vw, 1.85rem);
      line-height: 1.15;
    }

    #shopify-section-{{ section.id }} .favorites-subtitle {
      font-size: 0.9rem;
    }

    #shopify-section-{{ section.id }} .favorites-list {
      padding: 0.9rem;
      border-radius: 14px;
    }

    #shopify-section-{{ section.id }} .favorites-grid {
      gap: 0.75rem;
    }

    #shopify-section-{{ section.id }} .fav-item {
      grid-template-columns: 82px minmax(0, 1fr);
      gap: 0.75rem;
      padding: 0.75rem;
      border-radius: 10px;
      align-items: flex-start;
    }

    #shopify-section-{{ section.id }} .fav-image {
      width: 82px;
      height: 82px;
    }

    #shopify-section-{{ section.id }} .fav-title {
      font-size: 0.92rem;
      line-height: 1.3;
    }

    #shopify-section-{{ section.id }} .fav-price {
      font-size: 0.95rem;
    }

    #shopify-section-{{ section.id }} .fav-actions {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    #shopify-section-{{ section.id }} .fav-btn,
    #shopify-section-{{ section.id }} .fav-add-form {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .fav-btn {
      min-height: 40px;
      font-size: 0.84rem;
    }
  }

  @media (min-width: 980px) {
    #shopify-section-{{ section.id }} .favorites-shell {
      padding: 3rem 2rem 3rem;
    }

    #shopify-section-{{ section.id }} .favorites-header {
      margin-bottom: 2rem;
    }

    #shopify-section-{{ section.id }} .favorites-list {
      padding: 1.5rem;
    }

    #shopify-section-{{ section.id }} .fav-item {
      grid-template-columns: 132px minmax(0, 1fr);
      padding: 1.1rem;
    }

    #shopify-section-{{ section.id }} .fav-image {
      width: 132px;
      height: 132px;
    }

    #shopify-section-{{ section.id }} .fav-title {
      font-size: 1.06rem;
    }
  }
</style>

<section class="favorites-shell">
  <header class="favorites-header">
    <h1 class="favorites-title font-semibold">Meus favoritos</h1>
    <p class="favorites-subtitle">Os produtos salvos no coracao dos cards aparecem aqui automaticamente.</p>
  </header>

  <div class="favorites-layout">
    <article class="favorites-list">
      <p class="favorites-subtitle" data-favorites-page-loading>Carregando seus favoritos...</p>
      <p class="favorites-subtitle hidden" data-favorites-page-empty>Você ainda não possui itens favoritados.</p>
      <div class="favorites-grid" data-favorites-page-grid></div>
    </article>
  </div>
</section>
