{% liquid
  assign category_shape = section.settings.category_shape | default: 'circle'
  assign category_chip_radius = '9999px'
  assign section_bg = section.settings.section_bg_color | default: settings.global_surface_base_color
  assign section_text = section.settings.section_text_color | default: settings.global_text_primary_color
  assign section_border = section.settings.section_border_color | default: settings.global_border_color
  assign chip_bg = section.settings.category_bg_color | default: settings.global_surface_card_color
  assign title_color = section.settings.category_title_color | default: section_text
  assign categories_limit = section.settings.collections_limit | default: 60

  if category_shape == 'rounded_square'
    assign category_chip_radius = section.settings.corner_radius | append: 'px'
  endif
%}

<style>
  #shopify-section-{{ section.id }} .lc-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  #shopify-section-{{ section.id }} .lc-heading {
    font-size: clamp(1.35rem, 1.1rem + 1.2vw, 2.1rem);
    line-height: 1.15;
    color: var(--section-text);
  }

  #shopify-section-{{ section.id }} .lc-subtitle {
    color: color-mix(in srgb, var(--section-text) 75%, transparent);
  }

  #shopify-section-{{ section.id }} .lc-track {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .lc-track > div {
    min-width: 0;
    display: flex;
    justify-content: center;
    flex: 0 0 {{ section.settings.item_width_mobile }}px;
    max-width: {{ section.settings.item_width_mobile }}px;
  }

  #shopify-section-{{ section.id }} .lc-item {
    width: {{ section.settings.item_width_mobile }}px;
    margin-inline: auto;
    text-align: {{ section.settings.title_align }};
  }

  #shopify-section-{{ section.id }} .lc-media {
    width: {{ section.settings.item_width_mobile }}px;
    height: {{ section.settings.item_height_mobile }}px;
  }

  #shopify-section-{{ section.id }} .lc-media-image {
    width: 100%;
    height: 100%;
    transform: scale(1);
    transition: transform 0.35s ease;
  }

  #shopify-section-{{ section.id }} .lc-title {
    display: block;
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.25s ease;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .lc-item:hover .lc-media {
    border-color: var(--category-hover-border-color);
  }

  #shopify-section-{{ section.id }} .lc-item:hover .lc-title {
    color: var(--category-hover-title-color);
  }

  #shopify-section-{{ section.id }} .lc-item:hover .lc-media-image {
    transform: scale({{ section.settings.image_hover_scale }});
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .lc-track {
      justify-content: flex-start;
    }

    #shopify-section-{{ section.id }} .lc-track > div {
      flex-basis: {{ section.settings.item_width_desktop }}px;
      max-width: {{ section.settings.item_width_desktop }}px;
    }

    #shopify-section-{{ section.id }} .lc-item {
      width: {{ section.settings.item_width_desktop }}px;
    }

    #shopify-section-{{ section.id }} .lc-media {
      width: {{ section.settings.item_width_desktop }}px;
      height: {{ section.settings.item_height_desktop }}px;
    }
  }
</style>

<section class="section-layout-py" style="background-color: {{ section_bg }}; --section-bg: {{ section_bg }}; --section-text: {{ section_text }}; --section-border: {{ section_border }}; --category-chip-bg: {{ chip_bg }}; --category-title-color: {{ title_color }}; --category-hover-border-color: {{ section.settings.category_hover_border_color }}; --category-hover-title-color: {{ section.settings.category_hover_title_color }};">
  <div class="max-w-[1440px] mx-auto section-layout-px">
  <div class="lc-header mb-6 md:mb-6 lg:mb-8">
    <h1 class="lc-heading font-headline font-extrabold">{{ section.settings.title }}</h1>
    {% if section.settings.subtitle != blank %}
      <p class="lc-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="lc-track" style="gap: {{ section.settings.item_gap }}px;">
    {% assign rendered = 0 %}
    {% for collection in collections %}
      {% if rendered >= categories_limit %}
        {% break %}
      {% endif %}
      {% if collection.handle != 'all' and collection.handle != 'frontpage' %}
        {% liquid
          assign category_image = collection.featured_image
          assign category_image_url = ''

          if category_image == blank and collection.products_count > 0 and collection.products.first.featured_image != blank
            assign category_image = collection.products.first.featured_image
          endif

          if category_image != blank
            assign category_image_url = category_image | image_url: width: 900
          endif
        %}
        <div>
          <a class="lc-item group shrink-0" href="{{ collection.url }}" aria-label="Abrir coleção {{ collection.title | escape }}">
            <div class="lc-media mb-4 border-2 border-transparent transition-all overflow-hidden" style="background-color: var(--category-chip-bg, var(--color-surface)); border-radius: {{ category_chip_radius }};">
              <div class="lc-media-image" style="border-radius: {{ category_chip_radius }}; background-image: url('{{ category_image_url }}'); background-size: {{ section.settings.image_fit }}; background-position: {{ section.settings.image_position }}; background-repeat: {{ section.settings.image_repeat }};"></div>
            </div>
            <span class="lc-title font-bold block w-full" style="color: var(--category-title-color, var(--color-text)); font-size: {{ section.settings.title_size }}px; text-align: {{ section.settings.title_align }}; height: {{ section.settings.title_box_height }}px; line-height: {{ section.settings.title_box_height }}px;">{{ collection.title | truncate: 28 }}</span>
          </a>
        </div>
        {% assign rendered = rendered | plus: 1 %}
      {% endif %}
    {% endfor %}
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list custom",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Todas as coleções"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Navegue por todas as categorias disponíveis da loja."
    },
    {
      "type": "range",
      "id": "collections_limit",
      "label": "Quantidade máxima de coleções",
      "min": 6,
      "max": 200,
      "step": 2,
      "default": 60
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Cor de fundo da seção",
      "default": "#F7F7F7"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Cor do título e textos",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "section_border_color",
      "label": "Cor das bordas e controles",
      "default": "#d4d4d8"
    },
    {
      "type": "color",
      "id": "category_bg_color",
      "label": "Cor de fundo do card da categoria",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "category_title_color",
      "label": "Cor do nome da categoria",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "category_hover_border_color",
      "label": "Cor da borda no hover",
      "default": "#0058BB"
    },
    {
      "type": "color",
      "id": "category_hover_title_color",
      "label": "Cor do nome no hover",
      "default": "#0058BB"
    },
    {
      "type": "select",
      "id": "title_align",
      "label": "Alinhamento do texto",
      "default": "center",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ]
    },
    {
      "type": "range",
      "id": "item_width_desktop",
      "label": "Largura (desktop)",
      "min": 120,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 168
    },
    {
      "type": "range",
      "id": "item_height_desktop",
      "label": "Altura (desktop)",
      "min": 120,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 168
    },
    {
      "type": "range",
      "id": "item_width_mobile",
      "label": "Largura (mobile)",
      "min": 88,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 132
    },
    {
      "type": "range",
      "id": "item_height_mobile",
      "label": "Altura (mobile)",
      "min": 88,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 132
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Espaçamento entre cards",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamanho do título",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "title_box_height",
      "label": "Altura fixa do título",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Ajuste da imagem",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "100% 100%", "label": "Stretch (100% 100%)" },
        { "value": "auto", "label": "Auto" }
      ]
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posição da imagem",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Centro" },
        { "value": "top center", "label": "Topo" },
        { "value": "bottom center", "label": "Base" },
        { "value": "center left", "label": "Esquerda" },
        { "value": "center right", "label": "Direita" }
      ]
    },
    {
      "type": "select",
      "id": "image_repeat",
      "label": "Repetição da imagem",
      "default": "no-repeat",
      "options": [
        { "value": "no-repeat", "label": "Sem repetição" },
        { "value": "repeat", "label": "Repetir" },
        { "value": "repeat-x", "label": "Repetir horizontal" },
        { "value": "repeat-y", "label": "Repetir vertical" }
      ]
    },
    {
      "type": "range",
      "id": "image_hover_scale",
      "label": "Scale da imagem no hover",
      "min": 1,
      "max": 1.2,
      "step": 0.1,
      "default": 1.1
    },
    {
      "type": "select",
      "id": "category_shape",
      "label": "Formato da imagem",
      "default": "circle",
      "options": [
        { "value": "circle", "label": "Círculo" },
        { "value": "rounded_square", "label": "Quadrado arredondado" }
      ]
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Raio do quadrado arredondado",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection list custom"
    }
  ]
}
{% endschema %}
