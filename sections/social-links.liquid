{% liquid
  assign section_bg = section.settings.section_bg_color
  assign section_border = section.settings.section_border_color
%}

<section class="w-full section-layout-py border-t" style="--section-bg: {{ section_bg }}; --section-border: {{ section_border }}; --social-title-size-mobile: {{ section.settings.title_size_mobile }}px; --social-title-size-desktop: {{ section.settings.title_size_desktop }}px; --social-text-size-mobile: {{ section.settings.text_size_mobile }}px; --social-text-size-desktop: {{ section.settings.text_size_desktop }}px; --social-label-size-mobile: {{ section.settings.label_size_mobile }}px; --social-label-size-desktop: {{ section.settings.label_size_desktop }}px; --social-label-color: {{ section.settings.label_color }}; background-color: var(--section-bg); border-color: var(--section-border);">
  <div class="max-w-[1440px] mx-auto section-layout-px text-center">
    <h2 class="social-links__title font-headline font-extrabold mb-4 md:mb-6 uppercase tracking-tight" style="color: {{ section.settings.title_color }};">{{ section.settings.title }}</h2>
    <p class="social-links__text font-body mb-4 md:mb-6 max-w-lg mx-auto" style="color: {{ section.settings.text_color }};">{{ section.settings.text }}</p>

    <div class="social-links__list flex justify-center items-center flex-wrap">
      {% for block in section.blocks %}
        <div class="social-links__entry" {{ block.shopify_attributes }}>
          <a class="social-links__item" href="{{ block.settings.link }}" aria-label="{{ block.settings.label }}">
            <span class="social-links__icon" aria-hidden="true" style="--social-img-w-mobile: {{ block.settings.image_width_mobile | default: 22 }}px; --social-img-h-mobile: {{ block.settings.image_height_mobile | default: 22 }}px; --social-img-w-desktop: {{ block.settings.image_width_desktop | default: 24 }}px; --social-img-h-desktop: {{ block.settings.image_height_desktop | default: 24 }}px;">
              {% if block.settings.social_image != blank %}
                {{ block.settings.social_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.label, class: 'social-links__icon-image' }}
              {% else %}
                <span class="social-links__icon-fallback">{{ block.settings.label | slice: 0, 1 }}</span>
              {% endif %}
            </span>
          </a>
          {% if section.settings.show_label and block.settings.label != blank %}
            <p class="social-links__label">{{ block.settings.label }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .social-links__title {
    font-size: var(--social-title-size-mobile, 20px);
  }

  #shopify-section-{{ section.id }} .social-links__text {
    font-size: var(--social-text-size-mobile, 14px);
  }

  #shopify-section-{{ section.id }} .social-links__list {
    gap: {{ section.settings.items_gap_mobile }}px;
  }

  #shopify-section-{{ section.id }} .social-links__entry {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .social-links__item {
    width: auto;
    height: auto;
    color: inherit;
    text-decoration: none;
    box-shadow: none;
    transform: none;
    transition: none;
    filter: none;
    opacity: 1;
    -webkit-tap-highlight-color: transparent;
  }

  #shopify-section-{{ section.id }} .social-links__item:hover,
  #shopify-section-{{ section.id }} .social-links__item:focus,
  #shopify-section-{{ section.id }} .social-links__item:focus-visible,
  #shopify-section-{{ section.id }} .social-links__item:active {
    text-decoration: none;
    box-shadow: none;
    transform: none;
    transition: none;
    filter: none;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .social-links__icon-image {
    width: var(--social-img-w-mobile, 22px);
    height: var(--social-img-h-mobile, 22px);
    object-fit: contain;
    display: block;
    transform: none;
    transition: none;
    filter: none;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .social-links__item:hover .social-links__icon-image,
  #shopify-section-{{ section.id }} .social-links__item:focus .social-links__icon-image,
  #shopify-section-{{ section.id }} .social-links__item:active .social-links__icon-image {
    transform: none;
    transition: none;
    filter: none;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .social-links__icon-fallback {
    font-weight: 400;
    font-size: 14px;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .social-links__label {
    font-size: var(--social-label-size-mobile, 12px);
    color: var(--social-label-color, #52525b);
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .social-links__title {
      font-size: var(--social-title-size-desktop, 32px);
    }

    #shopify-section-{{ section.id }} .social-links__text {
      font-size: var(--social-text-size-desktop, 16px);
    }

    #shopify-section-{{ section.id }} .social-links__icon-image {
      width: var(--social-img-w-desktop, 24px);
      height: var(--social-img-h-desktop, 24px);
    }

    #shopify-section-{{ section.id }} .social-links__label {
      font-size: var(--social-label-size-desktop, 13px);
    }

    #shopify-section-{{ section.id }} .social-links__list {
      gap: {{ section.settings.items_gap_desktop }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Social links",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Siga-nos nas Redes Sociais"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Título (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 12,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Título (Desktop)",
      "default": 32
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do Título",
      "default": "#18181b"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Fique por dentro de todas as novidades e inspirações para sua casa."
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Texto (Mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Texto (Desktop)",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do Texto",
      "default": "#52525b"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Fundo da Seção",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "section_border_color",
      "label": "Cor da Borda da Seção",
      "default": "#e5e7eb"
    },
    {
      "type": "header",
      "content": "Itens Sociais"
    },
    {
      "type": "paragraph",
      "content": "O tamanho da imagem agora e configurado em cada item social (bloco)."
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Exibir rótulo abaixo do ícone",
      "default": true
    },
    {
      "type": "range",
      "id": "label_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Rótulo (Mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "label_size_desktop",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Tamanho do Rótulo (Desktop)",
      "default": 13
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Cor do Rótulo",
      "default": "#52525b"
    },
    {
      "type": "range",
      "id": "items_gap_mobile",
      "min": 4,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Espaçamento entre itens (Mobile)",
      "default": 18
    },
    {
      "type": "range",
      "id": "items_gap_desktop",
      "min": 4,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Espaçamento entre itens (Desktop)",
      "default": 24
    },
    {
      "type": "paragraph",
      "content": "Itens sociais trabalham somente com imagem e rótulo opcional."
    }
  ],
  "blocks": [
    {
      "type": "social_link",
      "name": "Link social",
      "settings": [
        {
          "type": "image_picker",
          "id": "social_image",
          "label": "Imagem do ícone social"
        },
        {
          "type": "range",
          "id": "image_width_mobile",
          "min": 0,
          "max": 400,
          "step": 4,
          "unit": "px",
          "label": "Largura (Mobile)",
          "default": 24
        },
        {
          "type": "range",
          "id": "image_height_mobile",
          "min": 0,
          "max": 400,
          "step": 4,
          "unit": "px",
          "label": "Altura (Mobile)",
          "default": 24
        },
        {
          "type": "range",
          "id": "image_width_desktop",
          "min": 0,
          "max": 600,
          "step": 6,
          "unit": "px",
          "label": "Largura (Desktop)",
          "default": 24
        },
        {
          "type": "range",
          "id": "image_height_desktop",
          "min": 0,
          "max": 600,
          "step": 6,
          "unit": "px",
          "label": "Altura (Desktop)",
          "default": 24
        },
        {
          "type": "text",
          "id": "label",
          "label": "Rótulo",
          "default": "Instagram"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social links",
      "blocks": [
        { "type": "social_link" },
        { "type": "social_link" },
        { "type": "social_link" },
        { "type": "social_link" },
        { "type": "social_link" }
      ]
    }
  ]
}
{% endschema %}
