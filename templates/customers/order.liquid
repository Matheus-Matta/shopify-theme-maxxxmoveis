{% assign first_line_item = order.line_items.first %}

<style>
	.order-detail-shell {
		max-width: 1320px;
		margin: 0 auto;
		padding: 2rem 1rem 3rem;
		background: #f1f2f4;
	}

	.order-detail-grid {
		display: grid;
		gap: 1.25rem;
	}

	.order-card,
	.order-summary {
		background: #fff;
		border: 1px solid #e2e5e9;
		border-radius: 8px;
	}

	.breadcrumbs {
		margin-bottom: 1rem;
		font-size: 0.95rem;
		color: #667487;
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}

	.breadcrumbs a {
		text-decoration: none;
		color: #667487;
	}

	.breadcrumbs strong {
		color: #1b2430;
	}

	.item-head {
		padding: 0.95rem;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 62px;
		gap: 0.8rem;
		align-items: center;
	}

	.item-head h2 {
		margin: 0;
		font-size: 1.05rem;
		color: #1b2430;
		font-weight: 400;
		line-height: 1.35;
	}

	.item-head p {
		margin: 0.35rem 0 0;
		font-size: 0.95rem;
		color: #5b6777;
	}

	.item-head a {
		color: #2563eb;
		text-decoration: none;
		font-weight: 400;
	}

	.item-thumb {
		width: 56px;
		height: 56px;
		border-radius: 999px;
		overflow: hidden;
		border: 1px solid #dfe4ea;
		background: #eef1f5;
	}

	.item-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.status-body {
		margin-top: 0.9rem;
		padding: 1.25rem;
	}

	.status-chip {
		margin: 0;
		color: #00a650;
		font-size: 1.05rem;
		font-weight: 400;
	}

	.status-title {
		margin: 0.4rem 0 0;
		color: #1b2430;
		font-size: 2rem;
		line-height: 1.1;
		font-weight: 400;
	}

	.status-text {
		margin: 1rem 0 0;
		color: #1f2b38;
		font-size: 1.1rem;
		line-height: 1.5;
	}

	.status-text strong {
		font-weight: 400;
	}

	.status-actions {
		margin-top: 1.1rem;
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}

	.status-actions a {
		text-decoration: none;
		border-radius: 7px;
		padding: 0.68rem 1rem;
		font-weight: 400;
		font-size: 0.98rem;
	}

	.btn-main {
		background: #3478f6;
		color: #fff;
	}

	.btn-alt {
		background: #eaf1ff;
		color: #3478f6;
	}

	.order-summary {
		padding: 1.25rem;
		height: fit-content;
	}

	.order-summary h3 {
		margin: 0;
		color: #0f1722;
		font-size: 2rem;
		line-height: 1.1;
		font-weight: 400;
	}

	.order-summary .summary-date {
		margin: 0.35rem 0 1rem;
		color: #6a7685;
		font-size: 0.95rem;
	}

	.summary-list {
		border-top: 1px solid #e8ebef;
		border-bottom: 1px solid #e8ebef;
		padding: 0.8rem 0;
		display: grid;
		gap: 0.65rem;
	}

	.summary-row {
		display: flex;
		justify-content: space-between;
		gap: 0.8rem;
		color: #415062;
		font-size: 1rem;
	}

	.summary-row.total {
		margin-top: 0.3rem;
		color: #111b27;
		font-weight: 400;
	}

	.summary-link {
		margin-top: 1rem;
		display: inline-flex;
		text-decoration: none;
		color: #2563eb;
		font-weight: 400;
		font-size: 1rem;
	}

	@media (min-width: 980px) {
		.order-detail-grid {
			grid-template-columns: minmax(0, 1fr) 380px;
			align-items: start;
		}

		.order-summary {
			position: sticky;
			top: 110px;
		}
	}
</style>

<section class="order-detail-shell">
	<div class="breadcrumbs">
		<a href="{{ routes.account_url }}">Compras</a>
		<span>></span>
		<strong>Status da compra</strong>
	</div>

	<div class="order-detail-grid">
		<div>
			<article class="order-card">
				<div class="item-head">
					<div>
						<h2>{{ first_line_item.title | default: 'Produto do pedido' }}</h2>
						<p>
							{{ first_line_item.quantity | default: 1 }} un. |
							<a href="{{ order.customer_url }}">Ver detalhe</a>
						</p>
					</div>
					<div class="item-thumb">
						{% if first_line_item.image %}
							<img src="{{ first_line_item.image | image_url: width: 180 }}" alt="{{ first_line_item.title | escape }}" loading="lazy" width="56" height="56">
						{% endif %}
					</div>
				</div>
			</article>

			<article class="order-card status-body">
				<p class="status-chip">{{ order.fulfillment_status_label }}</p>
				<h1 class="status-title">Chegou no dia {{ order.created_at | date: '%d de %B' }} ⚡ FULL</h1>

				{% if order.shipping_address %}
					<p class="status-text">
						Entregamos seu pacote em
						<strong>{{ order.shipping_address.address1 }}{% if order.shipping_address.address2 != blank %}, {{ order.shipping_address.address2 }}{% endif %}</strong>,
						{{ order.shipping_address.city }}{% if order.shipping_address.province != blank %}, {{ order.shipping_address.province }}{% endif %}.
					</p>
				{% endif %}

				<p class="status-text">Voce pode acompanhar novas atualizacoes no historico deste pedido.</p>

				<div class="status-actions">
					<a class="btn-main" href="{{ order.customer_url }}">Detalhes da entrega</a>
					<a class="btn-alt" href="{{ routes.all_products_collection_url }}">Comprar novamente</a>
				</div>
			</article>
		</div>

		<aside class="order-summary">
			<h3>Detalhe da compra</h3>
			<p class="summary-date">{{ order.created_at | date: '%d de %B' }} | # {{ order.name }}</p>

			<div class="summary-list">
				<div class="summary-row">
					<span>Produto</span>
					<strong>{{ order.line_items_subtotal_price | money }}</strong>
				</div>
				<div class="summary-row">
					<span>Desconto</span>
					<strong>- {{ order.total_discounts | money }}</strong>
				</div>
				<div class="summary-row">
					<span>Frete</span>
					<strong>{{ order.shipping_price | money }}</strong>
				</div>
				<div class="summary-row total">
					<span>Total</span>
					<strong>{{ order.total_price | money_with_currency }}</strong>
				</div>
			</div>

			<a class="summary-link" href="{{ routes.account_url }}">Detalhes do pagamento e envio</a>
		</aside>
	</div>
</section>
