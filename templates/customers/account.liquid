<section class="customer account page-width" style="padding: 2rem 1rem;">
  <h1>Minha Conta</h1>
  <div style="display:flex; justify-content:space-between; gap:2rem;">
    <div>
      <h2>Histórico de pedidos</h2>
      {% if customer.orders.size != 0 %}
        <ul>
          {% for order in customer.orders %}
            <li><a href="{{ order.customer_url }}">{{ order.name }}</a> - {{ order.created_at | date: "%d/%m/%Y" }} - {{ order.financial_status_label }} - {{ order.fulfillment_status_label }} - {{ order.total_price | money }}</li>
          {% endfor %}
        </ul>
      {% else %}
        <p>Você não fez nenhum pedido ainda.</p>
      {% endif %}
    </div>
    <div>
      <h2>Detalhes da conta</h2>
      {{ customer.default_address | format_address }}
      <a href="{{ routes.account_addresses_url }}">Ver endereços ({{ customer.addresses_count }})</a><br><br>
      <a href="/pages/favoritos">Meus Favoritos</a>
    </div>
  </div>
</section>
